<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Cloud MIN · Login</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{
  height:100%;font-family:'DM Sans',sans-serif;
  background:#0d0a1a;
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
  min-height:100vh;
}

/* ── Background canvas ── */
#bg-canvas{position:fixed;inset:0;z-index:0;pointer-events:none}

/* ── Sakura petals ── */
.petal{
  position:fixed;pointer-events:none;z-index:1;
  width:12px;height:12px;
  border-radius:50% 0 50% 0;
  background:linear-gradient(135deg,#ffb7c5,#ff85a1);
  opacity:0;
  animation:fall linear infinite;
}
@keyframes fall{
  0%{transform:translateY(-20px) rotate(0deg);opacity:.8}
  100%{transform:translateY(110vh) rotate(720deg);opacity:0}
}

/* ── Toast ── */
.toast{
  position:fixed;top:22px;left:50%;
  transform:translateX(-50%) translateY(-80px);
  background:rgba(20,10,40,.95);border:1px solid rgba(255,150,200,.25);
  border-radius:10px;padding:11px 18px;
  color:#ffe4f0;font-size:13px;white-space:nowrap;
  display:flex;align-items:center;gap:8px;
  transition:transform .4s cubic-bezier(.22,1,.36,1),opacity .4s;
  opacity:0;z-index:200;
  box-shadow:0 8px 32px rgba(255,100,180,.15);
}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.toast-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* ── Page ── */
.page{
  position:relative;z-index:10;
  display:flex;align-items:flex-end;gap:0;
  animation:pageIn .9s cubic-bezier(.22,1,.36,1) both;
}
@keyframes pageIn{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}

/* ── Character wrap ── */
.char-wrap{
  position:relative;
  width:210px;flex-shrink:0;
  align-self:flex-end;
  margin-right:-22px;
  z-index:2;
}
.char-svg{
  width:210px;
  filter:drop-shadow(0 12px 32px rgba(255,100,180,.4));
  animation:charFloat 3.5s ease-in-out infinite;
}
@keyframes charFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}

/* Shadow */
.char-shadow{
  width:100px;height:12px;margin:0 auto;
  background:radial-gradient(ellipse,rgba(255,100,180,.3) 0%,transparent 70%);
  animation:shadowFloat 3.5s ease-in-out infinite;
}
@keyframes shadowFloat{0%,100%{transform:scaleX(1);opacity:.6}50%{transform:scaleX(.75);opacity:.25}}

/* eyes react */
.eyes-normal{display:block}
.eyes-shy{display:none}
.eyes-happy{display:none}
body.peeking .eyes-normal{display:none}
body.peeking .eyes-shy{display:block}
body.success-state .eyes-normal{display:none}
body.success-state .eyes-happy{display:block}

/* blush */
.blush{opacity:0;transition:opacity .5s}
body.peeking .blush{opacity:1}
body.success-state .blush{opacity:1}

/* ── Login card ── */
.login-card{
  background:rgba(15,8,35,.82);
  border:1px solid rgba(255,150,200,.18);
  border-radius:22px;
  padding:38px 34px 34px;
  width:360px;
  backdrop-filter:blur(28px);
  position:relative;overflow:hidden;
  box-shadow:
    0 40px 80px rgba(0,0,0,.6),
    0 0 0 1px rgba(255,150,200,.06) inset,
    0 0 60px rgba(255,100,180,.06);
  z-index:1;
}
/* top shimmer */
.login-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(255,130,180,.7) 35%,rgba(200,100,255,1) 50%,rgba(255,130,180,.7) 65%,transparent);
  animation:shim 4s ease-in-out infinite;
}
@keyframes shim{0%,100%{opacity:.3}50%{opacity:1}}

/* card inner glow */
.login-card::after{
  content:'';position:absolute;bottom:-60px;right:-60px;
  width:180px;height:180px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,100,180,.08) 0%,transparent 70%);
  pointer-events:none;
}

.login-title{color:#fff5ff;font-size:21px;font-weight:700;letter-spacing:-.4px;margin-bottom:3px}
.login-sub{color:rgba(255,200,230,.38);font-size:12.5px;margin-bottom:28px}

/* ── Fields ── */
.field{margin-bottom:14px}
.field-label{
  display:block;color:rgba(255,180,220,.5);
  font-size:10.5px;font-weight:600;letter-spacing:.8px;text-transform:uppercase;
  margin-bottom:7px;transition:color .2s;
}
.field:focus-within .field-label{color:#f472b6}
.input-row{position:relative}
.input-ico{position:absolute;left:13px;top:50%;transform:translateY(-50%);pointer-events:none}
.input-ico svg{width:15px;height:15px;stroke:rgba(255,180,220,.3);transition:stroke .2s}
.field:focus-within .input-ico svg{stroke:#f472b6}

.field-input{
  width:100%;height:47px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,150,200,.14);
  border-radius:12px;
  color:#fff5ff;font-size:14px;font-family:'DM Sans',sans-serif;
  padding:0 40px 0 40px;
  outline:none;
  transition:border-color .2s,background .2s,box-shadow .2s;
}
.field-input::placeholder{color:rgba(255,180,220,.22)}
.field-input:focus{
  border-color:#c084fc;
  background:rgba(192,132,252,.07);
  box-shadow:0 0 0 3px rgba(192,132,252,.14);
}
.field-input.error{border-color:#fb7185;box-shadow:0 0 0 3px rgba(251,113,133,.1)}
.field-input.success{border-color:#4ade80;box-shadow:0 0 0 3px rgba(74,222,128,.1)}

.field-msg{font-size:11px;margin-top:4px;min-height:15px;padding-left:3px;transition:all .2s}
.field-msg.err{color:#fb7185}.field-msg.ok{color:#86efac}

/* eye toggle */
.eye-btn{
  position:absolute;right:11px;top:50%;transform:translateY(-50%);
  background:none;border:none;cursor:pointer;padding:4px;
  color:rgba(255,180,220,.3);transition:color .2s;
}
.eye-btn:hover{color:rgba(255,180,220,.8)}
.eye-btn svg{width:15px;height:15px;display:block}

/* strength */
.s-bar-wrap{margin-top:5px;display:none}
.s-bar-wrap.show{display:block}
.s-bar-bg{height:3px;background:rgba(255,255,255,.07);border-radius:10px;overflow:hidden}
.s-bar-fill{height:100%;border-radius:10px;width:0;transition:width .35s,background .35s}

/* ── Check row ── */
.check-row{display:flex;align-items:center;justify-content:space-between;margin:14px 0 22px}
.check-label{display:flex;align-items:center;gap:7px;cursor:pointer;color:rgba(255,180,220,.4);font-size:12.5px;user-select:none}
.custom-check{
  width:15px;height:15px;border-radius:4px;
  border:1.5px solid rgba(255,150,200,.25);background:transparent;
  display:flex;align-items:center;justify-content:center;
  transition:all .2s;flex-shrink:0;
}
#remember{display:none}
#remember:checked+.check-label .custom-check{background:#c084fc;border-color:#c084fc}
.forgot{color:#c084fc;font-size:12.5px;text-decoration:none;transition:color .15s}
.forgot:hover{color:#e879f9}

/* ── Button ── */
.btn-login{
  width:100%;height:50px;border:none;border-radius:13px;
  background:linear-gradient(135deg,#9333ea,#ec4899);
  color:#fff;font-size:15px;font-weight:700;font-family:'DM Sans',sans-serif;
  cursor:pointer;position:relative;overflow:hidden;
  transition:transform .15s,box-shadow .2s;
  box-shadow:0 6px 24px rgba(236,72,153,.35);
  letter-spacing:.2px;
}
.btn-login:hover{transform:translateY(-2px);box-shadow:0 12px 32px rgba(236,72,153,.5)}
.btn-login:active{transform:translateY(0)}
.btn-text{transition:opacity .2s}
.btn-login.loading .btn-text{opacity:0}
.btn-ripple{position:absolute;inset:0;pointer-events:none;background:rgba(255,255,255,.18);transform:scale(0);border-radius:50%;transition:transform .5s,opacity .5s;opacity:0}
.btn-login.rippling .btn-ripple{transform:scale(4);opacity:0}
.spinner{
  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
  width:20px;height:20px;
  border:2px solid rgba(255,255,255,.3);border-top-color:#fff;
  border-radius:50%;animation:spin .7s linear infinite;
  opacity:0;transition:opacity .2s;
}
@keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
.btn-login.loading .spinner{opacity:1}

@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-5px)}40%,80%{transform:translateX(5px)}}
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>

<div class="toast" id="toast">
  <div class="toast-dot" id="toast-dot"></div>
  <span id="toast-msg"></span>
</div>

<div class="page">

  <!-- ══════════════════════════════════════
       JAPANESE ANIME CHARACTER — Pure SVG
  ══════════════════════════════════════ -->
  <div class="char-wrap">
    <svg class="char-svg" viewBox="0 0 210 300" xmlns="http://www.w3.org/2000/svg">

