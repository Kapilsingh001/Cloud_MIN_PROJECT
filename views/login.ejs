<script>
/* ════════════════════════════════════
   1. AURORA WAVE BACKGROUND
════════════════════════════════════ */
(function(){
  const cv  = document.getElementById('aurora-canvas');
  const ctx = cv.getContext('2d');
  let W, H, t = 0;
  function resize(){ W = cv.width = innerWidth; H = cv.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);

  const waves = [
    { amp:0.08, freq:0.0018, speed:0.0006, phase:0,     r:57,  g:197, b:187, a:0.13 },
    { amp:0.06, freq:0.0024, speed:0.0009, phase:2.1,   r:100, g:220, b:210, a:0.10 },
    { amp:0.07, freq:0.0015, speed:0.0005, phase:4.2,   r:200, g:230, b:255, a:0.08 },
    { amp:0.05, freq:0.0030, speed:0.0012, phase:1.05,  r:255, g:180, b:200, a:0.07 },
    { amp:0.06, freq:0.0020, speed:0.0007, phase:3.14,  r:57,  g:197, b:187, a:0.09 },
  ];

  function draw(){
    t++;
    ctx.clearRect(0,0,W,H);

    waves.forEach((w,i)=>{
      ctx.beginPath();
      const baseY = H * (0.25 + i * 0.14);
      ctx.moveTo(0, baseY);
      for(let x=0; x<=W; x+=3){
        const y = baseY
          + Math.sin(x * w.freq + t * w.speed + w.phase) * H * w.amp
          + Math.sin(x * w.freq * 2.3 + t * w.speed * 1.7 + w.phase) * H * w.amp * 0.4;
        ctx.lineTo(x, y);
      }
      ctx.lineTo(W, H); ctx.lineTo(0, H); ctx.closePath();
      const grad = ctx.createLinearGradient(0, baseY - H*w.amp, 0, H);
      grad.addColorStop(0, `rgba(${w.r},${w.g},${w.b},${w.a})`);
      grad.addColorStop(1, `rgba(${w.r},${w.g},${w.b},0)`);
      ctx.fillStyle = grad; ctx.fill();
    });
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ════════════════════════════════════
   2. ENHANCED CONNECTED DOT NETWORK
      (mouse-attracted particles)
════════════════════════════════════ */
(function(){
  const cv  = document.getElementById('dot-canvas');
  const ctx = cv.getContext('2d');
  let W, H, mouse = { x: -999, y: -999 };

  function resize(){ W = cv.width = innerWidth; H = cv.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);
  document.addEventListener('mousemove', e => { mouse.x = e.clientX; mouse.y = e.clientY; });

  const DOTS = 70;
  const CONN = 140, ATTRACT = 160, ATTRACT_STR = 0.012;
  const TEAL = '57,197,187';

  const dots = Array.from({length: DOTS}, () => ({
    x:  Math.random() * innerWidth,
    y:  Math.random() * innerHeight,
    vx: (Math.random() - .5) * .5,
    vy: (Math.random() - .5) * .5,
    r:  Math.random() * 2 + .8,
    pulse: Math.random() * Math.PI * 2,
  }));

  function draw(){
    ctx.clearRect(0,0,W,H);

    dots.forEach(d => {
      // Mouse attraction
      const mx = mouse.x - d.x, my = mouse.y - d.y;
      const md = Math.sqrt(mx*mx + my*my);
      if(md < ATTRACT){
        const f = (1 - md/ATTRACT) * ATTRACT_STR;
        d.vx += mx * f; d.vy += my * f;
      }
      // Velocity damping
      d.vx *= 0.97; d.vy *= 0.97;
      d.x += d.vx; d.y += d.vy;
      if(d.x < 0 || d.x > W) d.vx *= -1;
      if(d.y < 0 || d.y > H) d.vy *= -1;
      d.pulse += 0.025;
    });

    // Draw connections
    for(let i=0; i<dots.length; i++){
      for(let j=i+1; j<dots.length; j++){
        const dx = dots[i].x - dots[j].x, dy = dots[i].y - dots[j].y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if(dist < CONN){
          const a = (1 - dist/CONN) * .45;
          ctx.beginPath();
          ctx.moveTo(dots[i].x, dots[i].y);
          ctx.lineTo(dots[j].x, dots[j].y);
          ctx.strokeStyle = `rgba(${TEAL},${a})`;
          ctx.lineWidth = .9; ctx.stroke();
        }
      }
    }

    // Draw dots with pulse
    dots.forEach(d => {
      const pr = d.r * (1 + 0.25 * Math.sin(d.pulse));
      // Glow
      const grd = ctx.createRadialGradient(d.x, d.y, 0, d.x, d.y, pr*4);
      grd.addColorStop(0, `rgba(${TEAL},.3)`);
      grd.addColorStop(1, `rgba(${TEAL},0)`);
      ctx.beginPath(); ctx.arc(d.x, d.y, pr*4, 0, Math.PI*2);
      ctx.fillStyle = grd; ctx.fill();
      // Core
      ctx.beginPath(); ctx.arc(d.x, d.y, pr, 0, Math.PI*2);
      ctx.fillStyle = `rgba(${TEAL},.7)`; ctx.fill();
    });

    requestAnimationFrame(draw);
  }
  draw();
})();

/* ════════════════════════════════════
   3. CLICK RIPPLE CANVAS
════════════════════════════════════ */
(function(){
  const cv  = document.getElementById('ripple-canvas');
  const ctx = cv.getContext('2d');
  let W, H;
  function resize(){ W = cv.width = innerWidth; H = cv.height = innerHeight; }
  resize(); window.addEventListener('resize', resize);

  const ripples = [];
  document.addEventListener('click', e => {
    ripples.push({ x: e.clientX, y: e.clientY, r: 0, maxR: 180, alpha: 0.6, speed: 4 });
    ripples.push({ x: e.clientX, y: e.clientY, r: 0, maxR: 100, alpha: 0.4, speed: 6 });
  });

  function draw(){
    ctx.clearRect(0,0,W,H);
    for(let i = ripples.length-1; i>=0; i--){
      const rp = ripples[i];
      rp.r += rp.speed;
      rp.alpha *= 0.94;
      if(rp.alpha < 0.01 || rp.r > rp.maxR){ ripples.splice(i,1); continue; }
      ctx.beginPath();
      ctx.arc(rp.x, rp.y, rp.r, 0, Math.PI*2);
      ctx.strokeStyle = `rgba(57,197,187,${rp.alpha})`;
      ctx.lineWidth = 2; ctx.stroke();
    }
    requestAnimationFrame(draw);
  }
  draw();
})();

/* ════════════════════════════════════
   4. FLOATING GEOMETRIC SHAPES
════════════════════════════════════ */
(function(){
  const layer = document.getElementById('geo-layer');
  const shapes = 22;
  const types  = ['square','circle','tri'];
  for(let i=0; i<shapes; i++){
    const el   = document.createElement('div');
    const type = types[Math.floor(Math.random()*types.length)];
    const size = Math.random()*36 + 14;
    const gx   = (Math.random()-0.5)*300 + 'px';
    const gy   = -(Math.random()*500+200) + 'px';
    const gr   = (Math.random()*720-360) + 'deg';
    const gs   = (Math.random()*0.6+0.7);
    el.className = 'geo ' + type;
    el.style.cssText = `
      left:${Math.random()*100}%;
      top:${Math.random()*100}%;
      width:${type==='tri'?0:size}px;
      height:${type==='tri'?0:size}px;
      --gx:${gx};--gy:${gy};--gr:${gr};--gs:${gs};
      animation-duration:${Math.random()*18+10}s;
      animation-delay:${Math.random()*12}s;
      opacity:0;
      ${type==='square'?`background:rgba(57,197,187,${Math.random()*0.07+0.03});`:''}
      ${type==='circle'?`background:rgba(57,197,187,${Math.random()*0.06+0.02});`:''}
      ${type==='tri'?`border-bottom-color:rgba(57,197,187,${Math.random()*0.10+0.05});border-bottom-width:${size*1.5}px;border-left-width:${size*0.9}px;border-right-width:${size*0.9}px;`:''}
      ${type!=='tri'?`border-color:rgba(57,197,187,${Math.random()*0.15+0.06});`:''}
    `;
    layer.appendChild(el);
  }
})();

/* ════════════════════════════════════
   5. MOUSE-REACTIVE GRADIENT MESH
════════════════════════════════════ */
(function(){
  const mesh = document.querySelector('.bg-mesh');
  document.addEventListener('mousemove', e => {
    const px = (e.clientX / innerWidth  * 100).toFixed(1) + '%';
    const py = (e.clientY / innerHeight * 100).toFixed(1) + '%';
    mesh.style.setProperty('--mx', px);
    mesh.style.setProperty('--my', py);
  });
})();

/* ════════════════════════════════════
   CURSOR GLOW FOLLOWER
════════════════════════════════════ */
const glow = document.getElementById('cursor-glow');
document.addEventListener('mousemove', e => {
  glow.style.left = e.clientX + 'px';
  glow.style.top  = e.clientY + 'px';
});

/* ════════════════════════════════════
   CARD 3D TILT ON MOUSE
════════════════════════════════════ */
const cardEl = document.getElementById('main-card');
const cardWrap = cardEl.parentElement;
cardWrap.addEventListener('mousemove', e => {
  if(window.innerWidth <= 700) return;
  const rect = cardWrap.getBoundingClientRect();
  const cx = rect.left + rect.width/2;
  const cy = rect.top  + rect.height/2;
  const dx = (e.clientX - cx) / (rect.width/2);
  const dy = (e.clientY - cy) / (rect.height/2);
  cardEl.style.transform = `rotateY(${dx*3.5}deg) rotateX(${-dy*2.5}deg)`;
});
cardWrap.addEventListener('mouseleave', () => {
  cardEl.style.transform = 'rotateY(0deg) rotateX(0deg)';
  cardEl.style.transition = 'transform .6s ease, box-shadow .3s';
  setTimeout(() => cardEl.style.transition = '', 600);
});

/* ════════════════════════════════════
   RIPPLE ON BUTTON CLICK
════════════════════════════════════ */
document.querySelectorAll('.btn-submit').forEach(btn => {
  btn.addEventListener('click', function(e){
    const r = document.createElement('span');
    r.className = 'btn-ripple';
    const rect = this.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height);
    r.style.cssText = `width:${size}px;height:${size}px;left:${e.clientX-rect.left-size/2}px;top:${e.clientY-rect.top-size/2}px`;
    this.appendChild(r);
    setTimeout(() => r.remove(), 650);
  });
});

/* ════════════════════════════════════
   PANEL SWITCH
════════════════════════════════════ */
const card    = document.getElementById('main-card');
const wTitle  = document.getElementById('w-title');
const wSub    = document.getElementById('w-sub');
const togBtn  = document.getElementById('toggle-btn');

let isSignup = false;
const serverTab = '<%= locals.tab || "login" %>';
if(serverTab === 'signup') { isSignup = true; }

function applyMode(animate){
  const loginPanel  = document.getElementById('login-panel');
  const signupPanel = document.getElementById('signup-panel');

  if(isSignup){
    card.classList.add('signup-mode');
    wTitle.textContent = 'Welcome Back!';
    wSub.innerHTML     = 'To keep connected with us<br>please login with your personal info';
    togBtn.querySelector('span').textContent = 'SIGN IN';
    loginPanel.classList.remove('active');
    if(animate){
      signupPanel.classList.remove('active');
      setTimeout(() => signupPanel.classList.add('active'), 350);
    } else {
      signupPanel.classList.add('active');
    }
  } else {
    card.classList.remove('signup-mode');
    wTitle.textContent = 'Hello, Friend!';
    wSub.innerHTML     = 'Enter your personal details<br>and start your journey with us';
    togBtn.querySelector('span').textContent = 'SIGN UP';
    signupPanel.classList.remove('active');
    if(animate){
      loginPanel.classList.remove('active');
      setTimeout(() => loginPanel.classList.add('active'), 350);
    } else {
      loginPanel.classList.add('active');
    }
  }

  // Animate title underline
  const titleEl = isSignup ? document.getElementById('signup-title') : document.getElementById('login-title');
  titleEl.classList.remove('underline-in');
  setTimeout(() => titleEl.classList.add('underline-in'), 450);
}

applyMode(false);
// Trigger underline on load
setTimeout(() => {
  const t = document.getElementById(isSignup ? 'signup-title' : 'login-title');
  t.classList.add('underline-in');
}, 300);

function switchMode(){
  isSignup = !isSignup;
  applyMode(true);
  showToast(isSignup ? '✦ Create your account' : '✦ Welcome back!');
}

/* ════════════════════════════════════
   TOAST
════════════════════════════════════ */
function showToast(msg, isErr){
  const t  = document.getElementById('toast');
  const td = document.getElementById('toast-dot');
  document.getElementById('toast-text').textContent = msg;
  td.style.background = isErr ? '#e53e3e' : '#39c5bb';
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

/* ════════════════════════════════════
   EYE TOGGLE
════════════════════════════════════ */
function toggleEye(inputId, iconId){
  const inp  = document.getElementById(inputId);
  const show = inp.type === 'text';
  inp.type   = show ? 'password' : 'text';
  document.getElementById(iconId).innerHTML = show
    ? '<path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>'
    : '<path d="M2 2l12 12M6.5 6.6A2 2 0 0010 10M9.88 9.88A2 2 0 016.1 6.1M1 8s3-5 7-5c1.25 0 2.43.37 3.44 1M15 8s-1.3 1.84-3.5 3.09" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
}

/* ════════════════════════════════════
   PASSWORD STRENGTH
════════════════════════════════════ */
document.getElementById('su-pass').addEventListener('input', function(){
  const v = this.value;
  const wrap = document.getElementById('s-wrap');
  const fill = document.getElementById('s-fill');
  const msg  = document.getElementById('su-pass-msg');
  if(!v){ wrap.classList.remove('show'); msg.textContent=''; this.classList.remove('is-ok','is-err'); return; }
  wrap.classList.add('show');
  let s=0;
  if(v.length>=6)s++; if(v.length>=10)s++; if(/[A-Z]/.test(v))s++; if(/[0-9]/.test(v))s++;
  const labs=['Too short','Weak','Fair','Strong','Very strong'];
  const cols=['#e53e3e','#f97316','#d69e2e','#38a169','#0d9488'];
  const ws  =['18%','36%','54%','78%','100%'];
  fill.style.width=ws[s]; fill.style.background=cols[s];
  msg.textContent='Strength: '+labs[s]; msg.style.color=cols[s]; msg.className='field-msg';
  this.classList.toggle('is-ok', s>=3);
  this.classList.toggle('is-err', s<2 && v.length>0);
});

/* ════════════════════════════════════
   LIVE VALIDATION
════════════════════════════════════ */
function attachLiveValidation(inpId, msgId, minLen, label){
  const inp = document.getElementById(inpId);
  const msg = document.getElementById(msgId);

  inp.addEventListener('input', function(){
    const v = this.value.trim();
    if(!v){ msg.textContent=''; msg.className='field-msg'; this.classList.remove('is-ok','is-err'); return; }
    if(v.length < minLen){
      msg.textContent = label + ' needs ' + (minLen - v.length) + ' more character' + (minLen-v.length===1?'':'s');
      msg.className='field-msg err-msg';
      this.classList.add('is-err'); this.classList.remove('is-ok');
    } else {
      msg.textContent = 'Looks good ✓';
      msg.className='field-msg ok-msg';
      this.classList.remove('is-err'); this.classList.add('is-ok');
    }
  });

  inp.addEventListener('blur', function(){
    if(this.value && this.value.trim().length < minLen){
      this.style.animation='none';
      requestAnimationFrame(()=>{ this.style.animation='shake .38s ease'; });
    }
  });
}

attachLiveValidation('li-user', 'li-user-msg', 3, 'Username');
attachLiveValidation('li-pass', 'li-pass-msg', 6, 'Password');
attachLiveValidation('su-user', 'su-user-msg', 3, 'Username');

/* ════════════════════════════════════
   SUBMIT HANDLER
════════════════════════════════════ */
function doSubmit(e, type){
  e.preventDefault();
  const isLogin = type === 'login';
  const userId  = isLogin ? 'li-user' : 'su-user';
  const passId  = isLogin ? 'li-pass' : 'su-pass';
  const uMsgId  = isLogin ? 'li-user-msg' : 'su-user-msg';
  const pMsgId  = isLogin ? 'li-pass-msg' : 'su-pass-msg';
  const btnId   = isLogin ? 'li-btn' : 'su-btn';
  const formId  = isLogin ? 'login-form' : 'signup-form';

  const uIn = document.getElementById(userId);
  const pIn = document.getElementById(passId);
  const btn = document.getElementById(btnId);
  let valid = true;

  if(!uIn.value.trim() || uIn.value.trim().length < 3){
    uIn.classList.add('is-err'); uIn.classList.remove('is-ok');
    document.getElementById(uMsgId).textContent = 'Username required (min 3 chars)';
    document.getElementById(uMsgId).className   = 'field-msg err-msg';
    uIn.style.animation='none';
    requestAnimationFrame(()=>{ uIn.style.animation='shake .38s ease'; });
    valid = false;
  }
  if(!pIn.value || pIn.value.length < 6){
    pIn.classList.add('is-err'); pIn.classList.remove('is-ok');
    document.getElementById(pMsgId).textContent = 'Password required (min 6 chars)';
    document.getElementById(pMsgId).className   = 'field-msg err-msg';
    if(valid){ pIn.style.animation='none'; requestAnimationFrame(()=>{ pIn.style.animation='shake .38s ease'; }); }
    valid = false;
  }
  // ✅ EMAIL VALIDATION (ONLY FOR SIGNUP)
if (type === 'signup') {
  if (!validateEmail('su-email')) {
    valid = false;
  }
}

  if(!valid){ showToast('Please fix the errors above', true); return false; }

  btn.classList.add('loading');
  showToast(isLogin ? '✦ Signing you in…' : '✦ Creating your account…');
  setTimeout(()=>{ document.getElementById(formId).submit(); }, 700);
  return false;
}

function validateUsername(inputId, msgId) {
  const val = document.getElementById(inputId).value.trim();
  const msg = document.getElementById(msgId);

  const regex = /^[a-zA-Z0-9_]+$/;

  if (!regex.test(val)) {
    msg.innerText = "Only letters, numbers, underscore allowed";
    msg.className = "field-msg err-msg";
    return false;
  }

  msg.innerText = "Valid username";
  msg.className = "field-msg ok-msg";
  return true;
}
function validateEmail(inputId) {
  const val = document.getElementById(inputId).value.trim();

  // ✅ Strict regex
  const regex = /^[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\.(com|org|net|edu|in)$/;

 if (val && (!regex.test(val) || !val.includes('.'))) {
  showToast("Enter a valid email (example: abc@gmail.com)", true);
  return false;
}

  return true;
}
</script>
