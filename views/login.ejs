<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Cloud MIN · Access</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --teal:#39c5bb;
  --teal-d:#2ba8a0;
  --teal-l:#5dd4cc;
  --teal-glow:rgba(57,197,187,.25);
  --white:#ffffff;
  --bg:#eef2f7;
  --text:#2d3748;
  --mid:#718096;
  --light:#a0aec0;
  --err:#e53e3e;
  --warn:#d69e2e;
  --ok:#38a169;
  --radius:24px;
  --shadow:0 24px 64px rgba(0,0,0,.13),0 8px 24px rgba(0,0,0,.07);
  --panel-w:780px;
  --panel-h:auto;
}

html,body{
  min-height:100vh;
  font-family:'Nunito',sans-serif;
  background:linear-gradient(135deg,#dff7f5 0%,#eef2f7 40%,#e8f4ff 70%,#f0e8ff 100%);
  display:flex;align-items:center;justify-content:center;
  padding:20px;
}

/* ════ BACKGROUND LAYERS ════ */
.bg-layer{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
#aurora-canvas{position:absolute;inset:0;opacity:.55}
#dot-canvas{position:absolute;inset:0;opacity:.55}
#ripple-canvas{position:absolute;inset:0;opacity:.7;pointer-events:none}
.bg-mesh{
  position:absolute;inset:-20%;width:140%;height:140%;
  background:
    radial-gradient(ellipse 55% 45% at var(--mx,15%) var(--my,80%), rgba(255,180,180,.22) 0%, transparent 65%),
    radial-gradient(ellipse 50% 50% at 85% 10%, rgba(57,197,187,.16) 0%, transparent 65%),
    radial-gradient(ellipse 40% 35% at 50% 50%, rgba(200,220,255,.14) 0%, transparent 65%);
  animation:meshShift 22s ease-in-out infinite;
}
@keyframes meshShift{
  0%,100%{filter:hue-rotate(0deg) saturate(1)}
  50%{filter:hue-rotate(-8deg) saturate(.95)}
}
.geo-layer{position:absolute;inset:0}
.geo{position:absolute;border:2px solid rgba(57,197,187,.18);animation:geoFloat linear infinite;will-change:transform,opacity}
.geo.square{border-radius:4px}
.geo.circle{border-radius:50%}
.geo.tri{width:0!important;height:0!important;border:none;border-left:20px solid transparent;border-right:20px solid transparent;border-bottom:35px solid rgba(57,197,187,.13);background:none!important}
@keyframes geoFloat{0%{transform:translate(0,0) rotate(0deg) scale(1);opacity:0}8%{opacity:1}92%{opacity:.7}100%{transform:translate(var(--gx),var(--gy)) rotate(var(--gr)) scale(var(--gs));opacity:0}}
.dec{position:absolute;border-radius:50%;opacity:.055}
.dec-1{width:420px;height:420px;background:var(--teal);top:-130px;right:-80px;animation:decFloat 14s ease-in-out infinite}
.dec-2{width:320px;height:320px;background:#e74c7c;bottom:-90px;left:-70px;animation:decFloat 18s ease-in-out infinite reverse}
@keyframes decFloat{0%,100%{transform:translate(0,0)}50%{transform:translate(18px,-18px)}}

/* ════ CARD ════ */
.card-wrap{position:relative;z-index:10;perspective:1200px;width:100%;max-width:var(--panel-w)}
.card{
  width:100%;
  background:var(--white);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
  display:flex;
  position:relative;
  transform-style:preserve-3d;
  transition:box-shadow .3s;
}
.card:hover{box-shadow:0 32px 80px rgba(0,0,0,.16),0 12px 32px rgba(0,0,0,.09)}

/* ════ SLIDING PANELS ════ */
.panel-form,.panel-welcome{
  position:relative;
  height:auto;width:50%;
  transition:transform .72s cubic-bezier(.77,0,.18,1),border-radius .72s cubic-bezier(.77,0,.18,1);
  will-change:transform;
  overflow:hidden;
  flex-shrink:0;
}
.panel-form{
  background:var(--white);
  display:flex;flex-direction:column;
  padding:36px 38px;
  z-index:2;
  border-radius:var(--radius) 0 0 var(--radius);
}
.panel-welcome{
  background:linear-gradient(145deg,var(--teal-l) 0%,var(--teal) 45%,var(--teal-d) 100%);
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  padding:40px 36px;
  z-index:1;
  border-radius:0 var(--radius) var(--radius) 0;
}
.card.signup-mode .panel-form{transform:translateX(100%);border-radius:0 var(--radius) var(--radius) 0}
.card.signup-mode .panel-welcome{transform:translateX(-100%);border-radius:var(--radius) 0 0 var(--radius)}

/* ── Welcome panel deco ── */
.panel-welcome::before{content:'';position:absolute;width:220px;height:220px;border-radius:50%;background:rgba(255,255,255,.07);bottom:-70px;right:-70px}
.panel-welcome::after{content:'';position:absolute;width:130px;height:130px;border-radius:50%;background:rgba(255,255,255,.05);top:30px;left:-40px}
.w-diamond{position:absolute;background:rgba(255,255,255,.1);transform:rotate(45deg);animation:wDiamondSpin linear infinite}
.w-diamond-1{width:64px;height:64px;top:56px;right:56px;animation-duration:22s}
.w-diamond-2{width:38px;height:38px;bottom:88px;left:52px;animation-duration:16s;animation-direction:reverse}
.w-diamond-3{width:24px;height:24px;top:140px;left:80px;animation-duration:28s;opacity:.6}
@keyframes wDiamondSpin{from{transform:rotate(45deg)}to{transform:rotate(405deg)}}
.w-ring{position:absolute;width:180px;height:180px;border-radius:50%;border:1.5px solid rgba(255,255,255,.15);animation:wRingPulse 3s ease-out infinite}
.w-ring:nth-child(2){animation-delay:1s;width:240px;height:240px}
.w-ring:nth-child(3){animation-delay:2s;width:300px;height:300px}
@keyframes wRingPulse{0%{transform:scale(.6);opacity:.8}100%{transform:scale(1.4);opacity:0}}
.welcome-title{font-size:26px;font-weight:900;color:#fff;text-align:center;margin-bottom:12px;letter-spacing:-.4px;position:relative;z-index:1}
.welcome-sub{font-size:13px;color:rgba(255,255,255,.82);text-align:center;line-height:1.65;position:relative;z-index:1;margin-bottom:28px}
.welcome-btn{
  position:relative;z-index:1;
  border:2px solid rgba(255,255,255,.9);background:transparent;color:#fff;
  font-family:'Nunito',sans-serif;font-size:12.5px;font-weight:800;letter-spacing:1.4px;text-transform:uppercase;
  padding:11px 40px;border-radius:50px;cursor:pointer;
  transition:background .22s,color .22s,transform .15s;overflow:hidden;
}
.welcome-btn::before{content:'';position:absolute;inset:0;background:#fff;border-radius:50px;transform:scaleX(0);transform-origin:right;transition:transform .3s cubic-bezier(.77,0,.18,1)}
.welcome-btn:hover::before{transform:scaleX(1);transform-origin:left}
.welcome-btn:hover{color:var(--teal)}
.welcome-btn span{position:relative;z-index:1}

/* ════ LOGO ════ */
.logo{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.logo-icon{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--teal),var(--teal-d));display:flex;align-items:center;justify-content:center;box-shadow:0 4px 14px var(--teal-glow);flex-shrink:0;transition:transform .2s}
.logo-icon:hover{transform:rotate(-6deg) scale(1.08)}
.logo-icon svg{width:18px;height:18px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}
.logo-text{font-size:15px;font-weight:800;color:var(--text);letter-spacing:-.2px}

/* ════ FORM TITLE ════ */
.form-title{font-size:21px;font-weight:800;color:var(--teal);text-align:center;margin-bottom:16px;letter-spacing:-.3px;position:relative;display:inline-block;align-self:center}
.form-title::after{content:'';position:absolute;bottom:-5px;left:50%;height:2.5px;border-radius:2px;background:linear-gradient(90deg,var(--teal-l),var(--teal-d));width:0;transition:width .5s cubic-bezier(.77,0,.18,1),left .5s cubic-bezier(.77,0,.18,1)}
.form-title.underline-in::after{width:80%;left:10%}

/* ════ SERVER MESSAGE BANNER ════ */
.srv-msg{border-radius:10px;padding:9px 13px;font-size:12px;margin-bottom:10px;display:flex;align-items:center;gap:8px;font-weight:600;animation:msgSlideIn .35s cubic-bezier(.22,1,.36,1) both}
@keyframes msgSlideIn{from{opacity:0;transform:translateY(-8px)}to{opacity:1;transform:translateY(0)}}
.srv-msg.err{background:#fff5f5;border:1px solid #fed7d7;color:var(--err)}
.srv-msg.ok{background:#f0fff4;border:1px solid #c6f6d5;color:var(--ok)}
.srv-msg.warn{background:#fffbeb;border:1px solid #fef08a;color:var(--warn)}
.srv-msg svg{width:13px;height:13px;flex-shrink:0}

/* ════ RATE LIMIT BANNER ════ */
.rate-banner{
  border-radius:10px;padding:10px 14px;font-size:12px;margin-bottom:10px;
  display:flex;align-items:center;gap:8px;font-weight:700;
  background:#fff5f5;border:1.5px solid #fc8181;color:var(--err);
  animation:msgSlideIn .35s cubic-bezier(.22,1,.36,1) both;
}
.rate-banner svg{width:14px;height:14px;flex-shrink:0}
.rate-timer{font-variant-numeric:tabular-nums;margin-left:auto;font-size:13px;background:var(--err);color:#fff;border-radius:6px;padding:1px 7px}

/* ════ FLOATING LABEL INPUTS ════ */
.field{position:relative;margin-bottom:10px}
.inp-wrap{position:relative;display:flex;align-items:center}
.inp-ico{position:absolute;left:14px;z-index:2;pointer-events:none;color:#c0c8d8;transition:color .25s,transform .25s}
.inp-ico svg{width:15px;height:15px;display:block}
.inp-wrap:focus-within .inp-ico{color:var(--teal);transform:scale(1.15)}
.field-input{
  width:100%;height:46px;
  border:1.5px solid #e2e8f0;border-radius:50px;
  background:#f7f8fc;
  padding:0 44px 0 42px;
  font-family:'Nunito',sans-serif;font-size:13.5px;color:var(--text);
  outline:none;
  transition:border-color .22s,background .22s,box-shadow .22s,transform .15s;
  caret-color:var(--teal);
}
.field-input::placeholder{color:#c0c8d8;font-size:13px}
.field-input:hover:not(:focus){background:#fff;border-color:#cbd5e0}
.field-input:focus{border-color:var(--teal);background:#fff;box-shadow:0 0 0 3.5px var(--teal-glow),0 2px 8px rgba(57,197,187,.1);transform:translateY(-1px)}
.field-input.is-err{border-color:var(--err)!important;box-shadow:0 0 0 3px rgba(229,62,62,.12)!important;transform:translateY(0)!important}
.field-input.is-ok{border-color:var(--ok);box-shadow:0 0 0 3px rgba(56,161,105,.10)}

/* ── Field tick ── */
.field-tick{position:absolute;right:42px;width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:900;color:#fff;opacity:0;transform:scale(0);transition:opacity .2s,transform .25s cubic-bezier(.34,1.56,.64,1);pointer-events:none}
.field-input.is-ok ~ .field-tick{opacity:1;transform:scale(1);background:var(--ok)}

/* ── Validation message ── */
.field-msg{font-size:11px;padding-left:16px;min-height:16px;margin-top:3px;transition:all .2s;font-weight:600;line-height:1.4}
.field-msg.err-msg{color:var(--err)}
.field-msg.ok-msg{color:var(--ok)}
.field-msg.warn-msg{color:var(--warn)}

/* ── Eye toggle ── */
.eye-btn{position:absolute;right:13px;z-index:2;background:none;border:none;cursor:pointer;color:#c0c8d8;padding:4px;transition:color .2s,transform .2s}
.eye-btn:hover{color:var(--teal);transform:scale(1.15)}
.eye-btn svg{width:14px;height:14px;display:block}

/* ── Strength bar ── */
.s-bar-wrap{margin-top:4px;padding:0 6px;display:none}
.s-bar-wrap.show{display:block}
.s-bar-bg{height:3.5px;background:#e2e8f0;border-radius:10px;overflow:hidden}
.s-bar-fill{height:100%;border-radius:10px;width:0;transition:width .35s,background .35s}
.s-bar-labels{display:flex;justify-content:space-between;margin-top:3px}
.s-bar-labels span{font-size:9px;color:#c0c8d8;font-weight:700;letter-spacing:.3px}

/* ── Password requirements checklist ── */
.pass-reqs{margin-top:6px;padding:8px 12px;background:#f7f8fc;border-radius:12px;display:none}
.pass-reqs.show{display:block}
.req-item{font-size:11px;font-weight:600;color:#c0c8d8;display:flex;align-items:center;gap:6px;line-height:1.8;transition:color .2s}
.req-item.met{color:var(--ok)}
.req-item.unmet{color:var(--err)}
.req-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex-shrink:0;transition:background .2s}

/* ════ FORGOT ════ */
.forgot-row{text-align:right;margin:-2px 0 12px}
.forgot{font-size:12px;color:var(--teal);font-weight:700;text-decoration:none;position:relative;transition:color .15s}
.forgot::after{content:'';position:absolute;bottom:-1px;left:0;right:0;height:1px;background:var(--teal);transform:scaleX(0);transform-origin:right;transition:transform .2s}
.forgot:hover::after{transform:scaleX(1);transform-origin:left}

/* ════ SUBMIT BUTTON ════ */
.btn-submit{
  width:100%;height:48px;border:none;border-radius:50px;
  background:linear-gradient(135deg,var(--teal-l) 0%,var(--teal) 50%,var(--teal-d) 100%);
  background-size:200% 100%;background-position:0% 50%;
  color:#fff;font-family:'Nunito',sans-serif;font-size:13px;font-weight:800;letter-spacing:1.2px;text-transform:uppercase;
  cursor:pointer;position:relative;overflow:hidden;
  transition:background-position .4s,transform .15s,box-shadow .2s,opacity .2s;
  box-shadow:0 6px 20px var(--teal-glow),0 2px 6px rgba(57,197,187,.3);
  margin-top:6px;
}
.btn-submit:hover:not(:disabled){background-position:100% 50%;transform:translateY(-2px);box-shadow:0 12px 28px var(--teal-glow)}
.btn-submit:active{transform:translateY(0)}
.btn-submit:disabled{opacity:.65;cursor:not-allowed;transform:none}
.btn-text{transition:opacity .2s,transform .2s;display:inline-block}
.btn-submit.loading .btn-text{opacity:0;transform:scale(.8)}
.btn-ripple{position:absolute;border-radius:50%;background:rgba(255,255,255,.35);transform:scale(0);animation:rippleGo .6s linear;pointer-events:none}
@keyframes rippleGo{to{transform:scale(4);opacity:0}}
.spinner{position:absolute;top:50%;left:50%;width:20px;height:20px;border:2.5px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .65s linear infinite;transform:translate(-50%,-50%);opacity:0;transition:opacity .2s}
@keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
.btn-submit.loading .spinner{opacity:1}
.progress-bar{position:absolute;bottom:0;left:0;height:2px;width:0%;background:rgba(255,255,255,.6);border-radius:0 0 50px 50px;transition:width .7s linear}
.btn-submit.loading .progress-bar{width:100%}

/* ════ PANEL VISIBILITY ════ */
.login-panel,.signup-panel{display:none;flex-direction:column;height:100%;animation:panelIn .4s cubic-bezier(.22,1,.36,1) both}
@keyframes panelIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.login-panel.active,.signup-panel.active{display:flex}

/* ════ DIVIDER ════ */
.divider-or{display:flex;align-items:center;gap:10px;color:#c0c8d8;font-size:11px;font-weight:600;letter-spacing:.5px;margin:8px 0}
.divider-or::before,.divider-or::after{content:'';flex:1;height:1px;background:#e2e8f0}

/* ════ TOAST ════ */
.toast{position:fixed;top:20px;left:50%;transform:translateX(-50%) translateY(-80px);background:#2d3748;color:#fff;border-radius:12px;padding:10px 18px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;z-index:200;white-space:nowrap;transition:transform .4s cubic-bezier(.22,1,.36,1),opacity .4s;opacity:0;box-shadow:0 8px 24px rgba(0,0,0,.18)}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.toast-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;background:var(--teal)}

/* ════ CURSOR GLOW ════ */
.cursor-glow{position:fixed;pointer-events:none;z-index:5;width:320px;height:320px;border-radius:50%;background:radial-gradient(circle,rgba(57,197,187,.08) 0%,transparent 70%);transform:translate(-50%,-50%);transition:left .12s ease,top .12s ease;will-change:left,top}

/* ════ SHAKE ════ */
@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-5px)}40%,80%{transform:translateX(5px)}}

/* ════ ATTEMPT COUNTER ════ */
.attempt-warn{font-size:11px;color:var(--warn);font-weight:700;text-align:center;margin-top:4px;min-height:16px}

/* ════ RESPONSIVE ════ */
@media(max-width:700px){
  :root{--panel-w:94vw}
  .card{flex-direction:column!important;height:auto}
  .panel-form,.panel-welcome{position:relative!important;left:auto!important;right:auto!important;width:100%!important;transform:none!important;border-radius:0!important;transition:none!important}
  .panel-form{padding:26px 20px;order:2}
  .panel-welcome{min-height:140px;padding:24px 20px;order:1}
  .card.signup-mode .panel-form{transform:none!important;order:2}
  .card.signup-mode .panel-welcome{transform:none!important;order:1}
  .card{border-radius:var(--radius)}
  .welcome-title{font-size:20px}
}
@media(max-width:400px){
  .panel-form{padding:20px 14px}
  .form-title{font-size:18px}
}
</style>
</head>
<body>

<div class="cursor-glow" id="cursor-glow"></div>

<!-- Animated background -->
<div class="bg-layer">
  <canvas id="aurora-canvas"></canvas>
  <canvas id="dot-canvas"></canvas>
  <canvas id="ripple-canvas"></canvas>
  <div class="geo-layer" id="geo-layer"></div>
  <div class="bg-mesh"></div>
  <div class="dec dec-1"></div>
  <div class="dec dec-2"></div>
</div>

<!-- Toast notification -->
<div class="toast" id="toast">
  <div class="toast-dot" id="toast-dot"></div>
  <span id="toast-text"></span>
</div>

<div class="card-wrap">
<div class="card" id="main-card">

  <!-- ══════ FORM PANEL ══════ -->
  <div class="panel-form" id="panel-form">

    <!-- ▸ LOGIN PANEL ▸ -->
    <div class="login-panel" id="login-panel">
      <div class="logo">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <span class="logo-text">Cloud MIN</span>
      </div>

      <div class="form-title" id="login-title">Sign in to Cloud MIN</div>

      <%# ── Server-side error/success banners ── %>
      <% if (locals.error && locals.tab !== 'signup') { %>
      <div class="srv-msg <%= locals.errorType === 'warn' ? 'warn' : 'err' %>">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <% if (locals.errorType === 'warn') { %>
            <path d="M8 2L14 14H2L8 2z"/><path d="M8 6v4M8 11.5v.5"/>
          <% } else { %>
            <circle cx="8" cy="8" r="6.5"/><path d="M8 5v3.5M8 11v.5"/>
          <% } %>
        </svg>
        <%- locals.error %>
      </div>
      <% } %>
      <% if (locals.success && locals.tab !== 'signup') { %>
      <div class="srv-msg ok">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="8" cy="8" r="6.5"/><path d="M5 8l2 2 4-4"/>
        </svg>
        <%- locals.success %>
      </div>
      <% } %>

      <%# ── Rate limit banner (shown when lockoutUntil passed) ── %>
      <% if (locals.lockoutSeconds && locals.lockoutSeconds > 0) { %>
      <div class="rate-banner" id="rate-banner">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="8" cy="8" r="6.5"/><path d="M8 4v5l3 2"/>
        </svg>
        Too many attempts. Try again in
        <span class="rate-timer" id="rate-timer"><%- locals.lockoutSeconds %>s</span>
      </div>
      <% } %>

      <form id="login-form" action="/login" method="POST" novalidate onsubmit="return doSubmit(event,'login')">
        <!-- CSRF token -->
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>">

        <%# ── Username / Email field ── %>
        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <circle cx="8" cy="5.5" r="2.5"/><path d="M2.5 13.5c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/>
              </svg>
            </span>
            <input class="field-input" id="li-user" name="username"
                   type="text" placeholder="Username or Email"
                   autocomplete="username"
                   maxlength="254"
                   value="<%= locals.prefill || '' %>">
            <span class="field-tick">✓</span>
          </div>
          <div class="field-msg" id="li-user-msg"></div>
        </div>

        <%# ── Password field ── %>
        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="2" y="7" width="12" height="8" rx="1.5"/><path d="M5 7V5a3 3 0 016 0v2"/>
              </svg>
