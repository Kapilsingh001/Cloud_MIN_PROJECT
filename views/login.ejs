<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Cloud MIN · Access</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --teal:#39c5bb;
  --teal-dark:#2ba8a0;
  --teal-light:#5dd4cc;
  --text-dark:#333;
  --text-mid:#666;
  --text-light:#999;
  --bg:#f0f4f8;
  --white:#ffffff;
  --error:#e74c3c;
  --success:#27ae60;
  --shadow:0 20px 60px rgba(0,0,0,.12);
  --radius:20px;
}

html,body{
  height:100%;min-height:100vh;
  font-family:'Nunito',sans-serif;
  background:var(--bg);
  display:flex;align-items:center;justify-content:center;
  overflow:hidden;
}

/* ── Decorative background shapes ── */
.bg-shapes{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.shape{position:absolute;border-radius:50%;opacity:.08}
.shape-1{width:500px;height:500px;background:var(--teal);top:-150px;right:-100px;animation:drift 14s ease-in-out infinite}
.shape-2{width:300px;height:300px;background:#e74c7c;bottom:-80px;left:-60px;animation:drift 18s ease-in-out infinite reverse}
.shape-3{width:200px;height:200px;background:#f59e0b;bottom:100px;right:200px;animation:drift 10s ease-in-out infinite 2s}
.shape-4{width:150px;height:150px;background:var(--teal);top:200px;left:100px;animation:drift 12s ease-in-out infinite 4s}
@keyframes drift{0%,100%{transform:translate(0,0) scale(1)}33%{transform:translate(20px,-20px) scale(1.04)}66%{transform:translate(-15px,15px) scale(.97)}}

/* ── Card ── */
.card{
  position:relative;z-index:10;
  width:760px;max-width:96vw;
  height:500px;
  background:var(--white);
  border-radius:var(--radius);
  box-shadow:var(--shadow);
  overflow:hidden;
  display:flex;
}

/* ── Panels ── */
.panel-form{
  width:50%;padding:40px 44px;
  display:flex;flex-direction:column;
  position:relative;z-index:2;
  background:var(--white);
  transition:transform .6s cubic-bezier(.77,0,.18,1),opacity .4s ease;
}
.panel-welcome{
  width:50%;position:relative;
  background:linear-gradient(135deg,var(--teal) 0%,#2bc0b4 60%,#1fa89e 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:40px 36px;overflow:hidden;
  transition:transform .6s cubic-bezier(.77,0,.18,1);
  flex-shrink:0;
}

/* Welcome panel decorative shapes */
.panel-welcome::before{
  content:'';position:absolute;width:200px;height:200px;border-radius:50%;
  background:rgba(255,255,255,.08);bottom:-60px;right:-60px;
}
.panel-welcome::after{
  content:'';position:absolute;width:120px;height:120px;border-radius:50%;
  background:rgba(255,255,255,.06);top:40px;left:-30px;
}
.welcome-diamond{
  position:absolute;width:60px;height:60px;
  background:rgba(255,255,255,.1);
  transform:rotate(45deg);
  top:60px;right:60px;
  animation:spin-slow 20s linear infinite;
}
.welcome-diamond2{
  position:absolute;width:35px;height:35px;
  background:rgba(255,255,255,.08);
  transform:rotate(45deg);
  bottom:90px;left:50px;
  animation:spin-slow 14s linear infinite reverse;
}
@keyframes spin-slow{to{transform:rotate(405deg)}}

.welcome-title{
  font-size:28px;font-weight:800;color:#fff;
  text-align:center;margin-bottom:14px;letter-spacing:-.3px;
  position:relative;z-index:1;
  animation:fadeInUp .5s ease both;
}
.welcome-sub{
  font-size:13.5px;color:rgba(255,255,255,.85);
  text-align:center;line-height:1.6;
  position:relative;z-index:1;
  margin-bottom:28px;
  animation:fadeInUp .5s .1s ease both;
}
.welcome-btn{
  position:relative;z-index:1;
  border:2px solid #fff;background:transparent;
  color:#fff;font-family:'Nunito',sans-serif;
  font-size:13px;font-weight:800;letter-spacing:1.2px;
  padding:12px 38px;border-radius:50px;cursor:pointer;
  text-transform:uppercase;
  transition:background .2s,color .2s,transform .15s,box-shadow .2s;
  animation:fadeInUp .5s .2s ease both;
}
.welcome-btn:hover{
  background:#fff;color:var(--teal);
  transform:scale(1.04);
  box-shadow:0 8px 24px rgba(0,0,0,.15);
}

/* ── Card states — sign-in (default) vs sign-up ── */
/* Default: form-left, welcome-right */
.card{flex-direction:row}

/* Signup mode: welcome-left, form-right */
.card.signup-mode{flex-direction:row-reverse}

/* Sliding animation */
.card .panel-form{
  animation:none;
}
.card.animating .panel-form{
  animation:slideForm .6s cubic-bezier(.77,0,.18,1) both;
}
.card.animating .panel-welcome{
  animation:slideWelcome .6s cubic-bezier(.77,0,.18,1) both;
}
@keyframes slideForm{from{opacity:.6;transform:translateX(-30px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideWelcome{from{opacity:.6;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
.card.signup-mode.animating .panel-form{
  animation:slideFormR .6s cubic-bezier(.77,0,.18,1) both;
}
.card.signup-mode.animating .panel-welcome{
  animation:slideWelcomeR .6s cubic-bezier(.77,0,.18,1) both;
}
@keyframes slideFormR{from{opacity:.6;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
@keyframes slideWelcomeR{from{opacity:.6;transform:translateX(-30px)}to{opacity:1;transform:translateX(0)}}

/* ── Logo ── */
.logo{display:flex;align-items:center;gap:10px;margin-bottom:20px}
.logo-icon{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,var(--teal),#2ba8a0);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px rgba(57,197,187,.35);
}
.logo-icon svg{width:18px;height:18px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round}
.logo-text{font-size:15px;font-weight:700;color:var(--text-dark);letter-spacing:-.2px}

/* ── Form title ── */
.form-title{
  font-size:22px;font-weight:800;color:var(--teal);
  text-align:center;margin-bottom:24px;letter-spacing:-.3px;
}



/* ── Server message ── */
.srv-msg{
  border-radius:10px;padding:9px 13px;font-size:12px;
  margin-bottom:12px;display:flex;align-items:center;gap:8px;
}
.srv-msg.err{background:#fef2f2;border:1px solid #fca5a5;color:var(--error)}
.srv-msg.ok{background:#f0fdf4;border:1px solid #86efac;color:var(--success)}
.srv-msg svg{width:13px;height:13px;flex-shrink:0}

/* ── Inputs ── */
.field{margin-bottom:12px;position:relative}
.inp-wrap{position:relative;display:flex;align-items:center}
.inp-ico{
  position:absolute;left:13px;
  pointer-events:none;
  color:#bbb;transition:color .2s;
}
.inp-ico svg{width:15px;height:15px;display:block}
.field-input{
  width:100%;height:44px;
  border:1.5px solid #e5e7eb;border-radius:50px;
  background:#f8f9fa;
  padding:0 42px 0 40px;
  font-family:'Nunito',sans-serif;font-size:13.5px;color:var(--text-dark);
  outline:none;
  transition:border-color .2s,background .2s,box-shadow .2s;
}
.field-input::placeholder{color:#bbb}
.field-input:hover{background:#fff;border-color:#d1d5db}
.field-input:focus{
  border-color:var(--teal);background:#fff;
  box-shadow:0 0 0 3px rgba(57,197,187,.12);
}
.field-input:focus~.inp-ico,.inp-wrap:focus-within .inp-ico{color:var(--teal)}
.field-input.err{border-color:var(--error);box-shadow:0 0 0 3px rgba(231,76,60,.1)}
.field-input.ok{border-color:var(--success)}
.field-msg{font-size:11px;color:var(--error);padding-left:14px;min-height:16px;margin-top:2px}
.field-msg.ok{color:var(--success)}

/* Eye toggle */
.eye-btn{
  position:absolute;right:13px;background:none;border:none;cursor:pointer;
  color:#bbb;padding:3px;transition:color .2s;
}
.eye-btn:hover{color:var(--teal)}
.eye-btn svg{width:14px;height:14px;display:block}

/* Forgot */
.forgot-row{text-align:right;margin:-4px 0 14px}
.forgot{font-size:12px;color:var(--teal);text-decoration:none;font-weight:600;transition:color .15s}
.forgot:hover{color:var(--teal-dark)}

/* ── Submit button ── */
.btn-submit{
  width:100%;height:46px;border:none;border-radius:50px;
  background:linear-gradient(135deg,var(--teal),#2ba8a0);
  color:#fff;font-family:'Nunito',sans-serif;
  font-size:13px;font-weight:800;letter-spacing:1px;
  text-transform:uppercase;cursor:pointer;
  position:relative;overflow:hidden;
  transition:transform .15s,box-shadow .2s;
  box-shadow:0 6px 20px rgba(57,197,187,.4);
  margin-top:4px;
}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(57,197,187,.5)}
.btn-submit:active{transform:translateY(0)}
.btn-text{transition:opacity .2s}
.btn-submit.loading .btn-text{opacity:0}
.spinner{
  position:absolute;top:50%;left:50%;
  transform:translate(-50%,-50%);
  width:18px;height:18px;
  border:2px solid rgba(255,255,255,.3);border-top-color:#fff;
  border-radius:50%;animation:spin .7s linear infinite;
  opacity:0;transition:opacity .2s;
}
@keyframes spin{to{transform:translate(-50%,-50%) rotate(360deg)}}
.btn-submit.loading .spinner{opacity:1}

/* ── Panel visibility ── */
.login-panel,.signup-panel{display:none}
.login-panel.active,.signup-panel.active{display:flex;flex-direction:column;height:100%}

/* ── Strength bar ── */
.s-bar-wrap{margin-top:4px;display:none;padding:0 4px}
.s-bar-wrap.show{display:block}
.s-bar-bg{height:3px;background:#e5e7eb;border-radius:10px;overflow:hidden}
.s-bar-fill{height:100%;border-radius:10px;width:0;transition:width .3s,background .3s}
.s-lbl{font-size:11px;color:var(--text-light);margin-top:3px}

/* ── Shake ── */
@keyframes shake{0%,100%{transform:translateX(0)}20%,60%{transform:translateX(-4px)}40%,80%{transform:translateX(4px)}}

/* ── Animations ── */
@keyframes fadeInUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

/* ── Responsive ── */
@media(max-width:640px){
  .card{flex-direction:column!important;height:auto;width:92vw}
  .panel-form{width:100%;padding:28px 24px}
  .panel-welcome{width:100%;padding:28px 24px;min-height:160px}
  .welcome-title{font-size:22px}
  .card.signup-mode{flex-direction:column-reverse!important}
}
</style>
</head>
<body>

<!-- Background shapes -->
<div class="bg-shapes">
  <div class="shape shape-1"></div>
  <div class="shape shape-2"></div>
  <div class="shape shape-3"></div>
  <div class="shape shape-4"></div>
</div>

<div class="card" id="main-card">

  <!-- ══ FORM PANEL ══ -->
  <div class="panel-form" id="panel-form">

    <!-- LOGIN panel -->
    <div class="login-panel" id="login-panel">
      <div class="logo">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <span class="logo-text">Cloud MIN</span>
      </div>

      <div class="form-title">Sign in to Cloud MIN</div>



      <% if (locals.error && locals.tab === 'login') { %>
      <div class="srv-msg err">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="8" cy="8" r="6.5"/><path d="M8 5v3.5M8 11v.5"/>
        </svg>
        <%= error %>
      </div>
      <% } %>

      <form id="login-form" action="/login" method="POST" onsubmit="return doSubmit(event,'login')">
        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <circle cx="8" cy="5.5" r="2.5"/><path d="M2.5 13.5c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/>
              </svg>
            </span>
            <input class="field-input" id="li-user" name="username" type="text"
                   placeholder="Username" autocomplete="username">
          </div>
          <div class="field-msg" id="li-user-msg"></div>
        </div>

        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="2" y="7" width="12" height="8" rx="1.5"/><path d="M5 7V5a3 3 0 016 0v2"/>
              </svg>
            </span>
            <input class="field-input" id="li-pass" name="password" type="password"
                   placeholder="Password" autocomplete="current-password">
            <button type="button" class="eye-btn" onclick="toggleEye('li-pass','eye-li')">
              <svg viewBox="0 0 16 16" fill="none" id="eye-li">
                <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
          </div>
          <div class="field-msg" id="li-pass-msg"></div>
        </div>

        <div class="forgot-row">
          <a href="#" class="forgot">Forgot your password?</a>
        </div>

        <button class="btn-submit" id="li-btn" type="submit">
          <span class="btn-text">SIGN IN</span>
          <div class="spinner"></div>
        </button>
      </form>
    </div>

    <!-- SIGNUP panel -->
    <div class="signup-panel" id="signup-panel">
      <div class="logo">
        <div class="logo-icon">
          <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <span class="logo-text">Cloud MIN</span>
      </div>

      <div class="form-title">Create Account</div>



      <% if (locals.error && locals.tab === 'signup') { %>
      <div class="srv-msg err">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="8" cy="8" r="6.5"/><path d="M8 5v3.5M8 11v.5"/>
        </svg>
        <%= error %>
      </div>
      <% } %>
      <% if (locals.success) { %>
      <div class="srv-msg ok">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <circle cx="8" cy="8" r="6.5"/><path d="M5 8l2 2 4-4"/>
        </svg>
        <%= success %>
      </div>
      <% } %>

      <form id="signup-form" action="/signup" method="POST" onsubmit="return doSubmit(event,'signup')">
        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <circle cx="8" cy="5.5" r="2.5"/><path d="M2.5 13.5c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/>
              </svg>
            </span>
            <input class="field-input" id="su-user" name="username" type="text"
                   placeholder="Name / Username" autocomplete="username">
          </div>
          <div class="field-msg" id="su-user-msg"></div>
        </div>

        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <path d="M2 3h12a1 1 0 011 1v8a1 1 0 01-1 1H2a1 1 0 01-1-1V4a1 1 0 011-1z"/>
                <polyline points="1 4 8 9 15 4"/>
              </svg>
            </span>
            <input class="field-input" id="su-email" name="email" type="email"
                   placeholder="Email (optional)" autocomplete="email">
          </div>
        </div>

        <div class="field">
          <div class="inp-wrap">
            <span class="inp-ico">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
                <rect x="2" y="7" width="12" height="8" rx="1.5"/><path d="M5 7V5a3 3 0 016 0v2"/>
              </svg>
            </span>
            <input class="field-input" id="su-pass" name="password" type="password"
                   placeholder="Password (min 6 chars)" autocomplete="new-password">
            <button type="button" class="eye-btn" onclick="toggleEye('su-pass','eye-su')">
              <svg viewBox="0 0 16 16" fill="none" id="eye-su">
                <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>
          </div>
          <div class="field-msg" id="su-pass-msg"></div>
          <div class="s-bar-wrap" id="s-wrap">
            <div class="s-bar-bg"><div class="s-bar-fill" id="s-fill"></div></div>
          </div>
        </div>

        <button class="btn-submit" id="su-btn" type="submit" style="margin-top:10px">
          <span class="btn-text">SIGN UP</span>
          <div class="spinner"></div>
        </button>
      </form>
    </div>

  </div><!-- /panel-form -->

  <!-- ══ WELCOME PANEL ══ -->
  <div class="panel-welcome" id="panel-welcome">
    <div class="welcome-diamond"></div>
    <div class="welcome-diamond2"></div>
    <div class="welcome-title" id="welcome-title">Hello, Friend!</div>
    <div class="welcome-sub" id="welcome-sub">
      Enter your personal details<br>and start your journey with us
    </div>
    <button class="welcome-btn" id="toggle-btn" onclick="switchMode()">SIGN UP</button>
  </div>

</div><!-- /card -->

<script>
const card     = document.getElementById('main-card');
const wTitle   = document.getElementById('welcome-title');
const wSub     = document.getElementById('welcome-sub');
const toggleBtn= document.getElementById('toggle-btn');

let isSignup = false;

// Read server-side tab
const serverTab = '<%= locals.tab || "login" %>';
if(serverTab === 'signup') {
  isSignup = true;
  applyMode(false); // apply without animation on load
}

function applyMode(animate){
  if(animate){ card.classList.add('animating'); }

  if(isSignup){
    card.classList.add('signup-mode');
    wTitle.textContent   = 'Welcome Back!';
    wSub.innerHTML       = 'To keep connected with us<br>please login with your personal info';
    toggleBtn.textContent= 'SIGN IN';
    document.getElementById('login-panel').classList.remove('active');
    document.getElementById('signup-panel').classList.add('active');
  } else {
    card.classList.remove('signup-mode');
    wTitle.textContent   = 'Hello, Friend!';
    wSub.innerHTML       = 'Enter your personal details<br>and start your journey with us';
    toggleBtn.textContent= 'SIGN UP';
    document.getElementById('signup-panel').classList.remove('active');
    document.getElementById('login-panel').classList.add('active');
  }

  if(animate){
    setTimeout(()=> card.classList.remove('animating'), 700);
  }
}

// Init
applyMode(false);

function switchMode(){
  isSignup = !isSignup;
  applyMode(true);
}

/* ── Eye toggle ── */
function toggleEye(inputId, iconId){
  const inp = document.getElementById(inputId);
  const show= inp.type === 'text';
  inp.type  = show ? 'password' : 'text';
  document.getElementById(iconId).innerHTML = show
    ? '<path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>'
    : '<path d="M2 2l12 12M6.5 6.6A2 2 0 0010 10M9.88 9.88A2 2 0 016.1 6.1M1 8s3-5 7-5c1.25 0 2.43.37 3.44 1M15 8s-1.3 1.84-3.5 3.09" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
}

/* ── Password strength ── */
document.getElementById('su-pass').addEventListener('input', function(){
  const v = this.value;
  const wrap= document.getElementById('s-wrap');
  const fill= document.getElementById('s-fill');
  const msg = document.getElementById('su-pass-msg');
  if(!v){ wrap.classList.remove('show'); msg.textContent=''; return; }
  wrap.classList.add('show');
  let s=0;
  if(v.length>=6)s++;if(v.length>=10)s++;if(/[A-Z]/.test(v))s++;if(/[0-9]/.test(v))s++;
  const labs=['Too short','Weak','Fair','Strong','Very strong'];
  const cols=['#ef4444','#f97316','#eab308','#22c55e','#10b981'];
  const ws  =['18%','36%','54%','76%','100%'];
  fill.style.width=ws[s];fill.style.background=cols[s];
  msg.textContent='Strength: '+labs[s];
  msg.style.color=cols[s];msg.className='field-msg';
});

/* ── Inline validation ── */
function attachVal(inpId, msgId, minLen, label){
  document.getElementById(inpId).addEventListener('blur', function(){
    const v=this.value.trim(), m=document.getElementById(msgId);
    if(!v){m.textContent='';m.className='field-msg';this.classList.remove('err','ok');return;}
    if(v.length<minLen){
      m.textContent=label+' must be at least '+minLen+' characters';
      m.className='field-msg';this.classList.add('err');this.classList.remove('ok');
    } else {
      m.textContent='Looks good ✓';m.className='field-msg ok';
      this.classList.remove('err');this.classList.add('ok');
    }
  });
}
attachVal('li-user','li-user-msg',3,'Username');
attachVal('li-pass','li-pass-msg',6,'Password');
attachVal('su-user','su-user-msg',3,'Username');

/* ── Submit ── */
function doSubmit(e, type){
  e.preventDefault();
  const isLogin = type === 'login';
  const userId  = isLogin ? 'li-user' : 'su-user';
  const passId  = isLogin ? 'li-pass' : 'su-pass';
  const uMsgId  = isLogin ? 'li-user-msg' : 'su-user-msg';
  const pMsgId  = isLogin ? 'li-pass-msg' : 'su-pass-msg';
  const btnId   = isLogin ? 'li-btn' : 'su-btn';
  const formId  = isLogin ? 'login-form' : 'signup-form';

  const uIn = document.getElementById(userId);
  const pIn = document.getElementById(passId);
  const btn = document.getElementById(btnId);
  let valid = true;

  if(!uIn.value.trim() || uIn.value.trim().length < 3){
    uIn.classList.add('err');uIn.classList.remove('ok');
    document.getElementById(uMsgId).textContent='Username required (min 3 chars)';
    document.getElementById(uMsgId).className='field-msg';
    uIn.style.animation='none';requestAnimationFrame(()=>{uIn.style.animation='shake .35s ease';});
    valid=false;
  }
  if(!pIn.value || pIn.value.length < 6){
    pIn.classList.add('err');pIn.classList.remove('ok');
    document.getElementById(pMsgId).textContent='Password required (min 6 chars)';
    document.getElementById(pMsgId).className='field-msg';
    if(valid){pIn.style.animation='none';requestAnimationFrame(()=>{pIn.style.animation='shake .35s ease';});}
    valid=false;
  }

  if(!valid) return false;

  btn.classList.add('loading');
  setTimeout(()=>{ document.getElementById(formId).submit(); }, 600);
  return false;
}
</script>
</body>
</html>
