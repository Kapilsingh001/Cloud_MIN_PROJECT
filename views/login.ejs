        <circle cx="85" cy="102" r="6" fill="#1e0a3c"/>
        <circle cx="127" cy="102" r="6" fill="#1e0a3c"/>
        <!-- sparkle big -->
        <circle cx="88" cy="97" r="3.5" fill="white"/>
        <circle cx="130" cy="97" r="3.5" fill="white"/>
        <!-- sparkle small -->
        <circle cx="80" cy="107" r="1.5" fill="rgba(255,255,255,.6)"/>
        <circle cx="122" cy="107" r="1.5" fill="rgba(255,255,255,.6)"/>
        <!-- bottom eyelid shimmer -->
        <path d="M70 110 Q84 116 98 110" stroke="#e9d5ff" stroke-width="1" fill="none" opacity=".5"/>
        <path d="M112 110 Q126 116 140 110" stroke="#e9d5ff" stroke-width="1" fill="none" opacity=".5"/>
