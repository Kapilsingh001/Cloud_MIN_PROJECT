  <!-- ══════════════════════════════════════
       LOGIN CARD
  ══════════════════════════════════════ -->
  <div class="login-card">
    <div class="login-title">ようこそ！ Welcome back</div>
    <div class="login-sub">Cloud MIN Project · Secure Access</div>

    <form id="login-form" action="/login" method="POST" onsubmit="return handleLogin(event)">

      <!-- Username -->
      <div class="field">
        <label class="field-label" for="username-in">Username</label>
        <div class="input-row">
          <div class="input-ico">
            <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
              <circle cx="8" cy="5.5" r="2.5"/>
              <path d="M2.5 13.5c0-3 2.5-5 5.5-5s5.5 2 5.5 5"/>
            </svg>
          </div>
          <input class="field-input" id="username-in" name="username"
                 type="text" placeholder="Enter username" autocomplete="off">
        </div>
        <div class="field-msg" id="user-msg"></div>
      </div>

      <!-- Password -->
      <div class="field">
        <label class="field-label" for="pass-in">Password</label>
        <div class="input-row">
          <div class="input-ico">
            <svg viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
              <rect x="2" y="7" width="12" height="8" rx="1.5"/>
              <path d="M5 7V5a3 3 0 016 0v2"/>
            </svg>
          </div>
          <input class="field-input" id="pass-in" name="password"
                 type="password" placeholder="Enter password">
          <button type="button" class="eye-btn" onclick="togglePw()">
            <svg viewBox="0 0 16 16" fill="none" id="eye-icon">
              <path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </button>
        </div>
        <div class="field-msg" id="pass-msg"></div>
        <div class="s-bar-wrap" id="s-bar-wrap">
          <div class="s-bar-bg"><div class="s-bar-fill" id="s-bar"></div></div>
        </div>
      </div>

      <!-- Remember / Forgot -->
      <div class="check-row">
        <input type="checkbox" id="remember">
        <label class="check-label" for="remember">
          <div class="custom-check">
            <svg id="check-tick" width="10" height="10" viewBox="0 0 10 10" fill="none"
                 stroke="white" stroke-width="1.8" stroke-linecap="round"
                 style="opacity:0;transition:opacity .15s">
              <polyline points="2,5 4.5,7.5 8,3"/>
            </svg>
          </div>
          Remember me
        </label>
        <a href="#" class="forgot">Forgot password?</a>
      </div>

      <button class="btn-login" id="login-btn" type="submit">
        <span class="btn-text">Sign in &nbsp;→</span>
        <div class="btn-ripple"></div>
        <div class="spinner"></div>
      </button>

    </form>
  </div>
</div>

<script>
/* ════════════════════════════════════════
   BACKGROUND — Japanese night scene
════════════════════════════════════════ */
const cv  = document.getElementById('bg-canvas');
const ctx = cv.getContext('2d');
let W, H;

function resize(){ W = cv.width = innerWidth; H = cv.height = innerHeight; }
resize(); window.addEventListener('resize', ()=>{ resize(); drawBg(); });

/* stars */
const stars = Array.from({length:200},()=>({
  x:Math.random(), y:Math.random(),
  r:Math.random()*1.4+.2,
  a:Math.random()*.8+.2,
  blink:Math.random()*Math.PI*2,
  speed:Math.random()*.02+.005
}));

/* moon */
function drawMoon(t){
  const mx = W*.78, my = H*.18, mr = Math.min(W,H)*.075;
  // moon glow
  const grd = ctx.createRadialGradient(mx,my,0,mx,my,mr*3);
  grd.addColorStop(0,'rgba(255,240,200,.14)');
  grd.addColorStop(1,'transparent');
  ctx.beginPath(); ctx.arc(mx,my,mr*3,0,Math.PI*2);
  ctx.fillStyle=grd; ctx.fill();
  // moon body
  const mg = ctx.createRadialGradient(mx-mr*.25,my-mr*.25,0,mx,my,mr);
  mg.addColorStop(0,'#fffbeb');
  mg.addColorStop(.6,'#fef3c7');
  mg.addColorStop(1,'#fde68a');
  ctx.beginPath(); ctx.arc(mx,my,mr,0,Math.PI*2);
  ctx.fillStyle=mg; ctx.fill();
  // moon shadow (crescent shadow)
  ctx.beginPath(); ctx.arc(mx+mr*.3,my-mr*.15,mr*.8,0,Math.PI*2);
  ctx.fillStyle='rgba(13,10,26,.55)'; ctx.fill();
}

/* torii gate */
function drawTorii(){
  const cx2=W*.12, cy2=H, tw=W*.14, th=H*.42;
  const top=cy2-th, pilW=tw*.09;
  ctx.save();
  // pillars
  ctx.fillStyle='#c2410c';
  ctx.fillRect(cx2-tw*.4, top+th*.08, pilW, th);
  ctx.fillRect(cx2+tw*.4-pilW, top+th*.08, pilW, th);
  // top beam (kasagi) curved
  ctx.beginPath();
  ctx.moveTo(cx2-tw*.52, top+th*.04);
  ctx.quadraticCurveTo(cx2, top-th*.04, cx2+tw*.52, top+th*.04);
  ctx.lineWidth=tw*.12; ctx.strokeStyle='#c2410c'; ctx.stroke();
  // second beam (nuki)
  ctx.fillStyle='#b91c1c';
  ctx.fillRect(cx2-tw*.42, top+th*.18, tw*.84, tw*.09);
  // small top center post
  ctx.fillStyle='#ef4444';
  ctx.fillRect(cx2-pilW*.5, top-th*.07, pilW, th*.12);
  ctx.restore();
}

/* mountains */
function drawMountains(){
  // far mountains
  ctx.beginPath();
  ctx.moveTo(0,H*.7);
  ctx.lineTo(W*.15,H*.35);
  ctx.lineTo(W*.3,H*.55);
  ctx.lineTo(W*.45,H*.28);
  ctx.lineTo(W*.6,H*.48);
  ctx.lineTo(W*.75,H*.22);
  ctx.lineTo(W*.9,H*.45);
  ctx.lineTo(W,H*.38);
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  const mg=ctx.createLinearGradient(0,H*.2,0,H*.7);
  mg.addColorStop(0,'#2d1b4e');
  mg.addColorStop(1,'#1a0a2e');
  ctx.fillStyle=mg; ctx.fill();

  // near hills
  ctx.beginPath();
  ctx.moveTo(0,H*.85);
  ctx.bezierCurveTo(W*.2,H*.65,W*.4,H*.78,W*.55,H*.7);
  ctx.bezierCurveTo(W*.7,H*.62,W*.85,H*.75,W,H*.68);
  ctx.lineTo(W,H);ctx.lineTo(0,H);ctx.closePath();
  const hg=ctx.createLinearGradient(0,H*.65,0,H);
  hg.addColorStop(0,'#1e0a38');
  hg.addColorStop(1,'#0d0520');
  ctx.fillStyle=hg; ctx.fill();
}

/* sakura tree */
function drawTree(){
  const tx=W*.88, ty=H*.72;
  // trunk
  ctx.strokeStyle='#3b1a08'; ctx.lineWidth=8;
  ctx.beginPath(); ctx.moveTo(tx,H); ctx.quadraticCurveTo(tx-10,ty+60,tx-5,ty); ctx.stroke();
  // branches
  ctx.lineWidth=4;
  ctx.beginPath(); ctx.moveTo(tx-5,ty); ctx.quadraticCurveTo(tx-50,ty-40,tx-80,ty-20); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(tx-5,ty+20); ctx.quadraticCurveTo(tx+40,ty-20,tx+60,ty-50); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(tx-5,ty); ctx.quadraticCurveTo(tx-10,ty-60,tx+10,ty-90); ctx.stroke();
  // blossom clusters
  const blossomPos=[
    [tx-80,ty-20],[tx-65,ty-45],[tx-55,ty-65],
    [tx-30,ty-85],[tx+10,ty-90],[tx+30,ty-75],
    [tx+60,ty-50],[tx+45,ty-25]
  ];
  blossomPos.forEach(([bx,by])=>{
    for(let i=0;i<8;i++){
      const angle=Math.random()*Math.PI*2;
      const dist=Math.random()*22;
      const px=bx+Math.cos(angle)*dist, py=by+Math.sin(angle)*dist;
      ctx.beginPath(); ctx.arc(px,py,Math.random()*5+3,0,Math.PI*2);
      const pink=Math.random()>.5?'rgba(255,182,193,.75)':'rgba(255,105,155,.55)';
      ctx.fillStyle=pink; ctx.fill();
    }
  });
}

/* lanterns */
function drawLanterns(t){
  const lans=[{x:.22,y:.48},{x:.35,y:.52},{x:.58,y:.44}];
  lans.forEach((l,i)=>{
    const lx=W*l.x, ly=H*l.y;
    const sway=Math.sin(t*.0008+i*1.5)*4;
    ctx.save(); ctx.translate(sway,0);
    // string
    ctx.strokeStyle='rgba(255,220,150,.4)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(lx,ly-30); ctx.lineTo(lx,ly); ctx.stroke();
    // lantern body glow
    const lg=ctx.createRadialGradient(lx,ly,0,lx,ly,25);
    lg.addColorStop(0,'rgba(255,180,60,.25)');
    lg.addColorStop(1,'transparent');
    ctx.beginPath(); ctx.arc(lx,ly,25,0,Math.PI*2);
    ctx.fillStyle=lg; ctx.fill();
    // lantern body
    ctx.beginPath();
    ctx.ellipse(lx,ly,12,16,0,0,Math.PI*2);
    ctx.fillStyle='rgba(220,80,20,.85)'; ctx.fill();
    ctx.strokeStyle='rgba(255,150,60,.6)'; ctx.lineWidth=1; ctx.stroke();
    // lantern bands
    ctx.strokeStyle='rgba(200,60,10,.7)'; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.moveTo(lx-12,ly); ctx.lineTo(lx+12,ly); ctx.stroke();
    // top/bottom caps
    ctx.fillStyle='rgba(150,40,10,.9)';
    ctx.fillRect(lx-7,ly-17,14,4);
    ctx.fillRect(lx-7,ly+13,14,4);
    ctx.restore();
  });
}

/* ground / water reflection */
function drawGround(){
  const gg=ctx.createLinearGradient(0,H*.82,0,H);
  gg.addColorStop(0,'#0d0520');
  gg.addColorStop(1,'#070310');
  ctx.fillStyle=gg;
  ctx.fillRect(0,H*.82,W,H*.18);

  // water shimmer lines
  for(let i=0;i<6;i++){
    const wy=H*(.86+i*.022);
    ctx.beginPath();
    ctx.moveTo(W*.1,wy); ctx.lineTo(W*.9,wy);
    ctx.strokeStyle=`rgba(200,150,255,${.04+i*.005})`;
    ctx.lineWidth=.5; ctx.stroke();
  }
}

/* sky gradient */
function drawSky(){
  const sg=ctx.createLinearGradient(0,0,0,H);
  sg.addColorStop(0,'#03000d');
  sg.addColorStop(.3,'#0d0520');
  sg.addColorStop(.6,'#1a0a2e');
  sg.addColorStop(1,'#0d0a1a');
  ctx.fillStyle=sg;
  ctx.fillRect(0,0,W,H);
}

let animT=0;
function drawBg(){
  animT++;
  ctx.clearRect(0,0,W,H);
  drawSky();

  // stars
  stars.forEach(s=>{
    const a=s.a*(0.5+0.5*Math.sin(animT*s.speed+s.blink));
    ctx.beginPath(); ctx.arc(s.x*W,s.y*H*.6,s.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(230,210,255,${a})`; ctx.fill();
  });

  drawMoon(animT);
  drawMountains();
  drawTree();
  drawTorii();
  drawLanterns(animT);
  drawGround();
  requestAnimationFrame(drawBg);
}
drawBg();

/* ── Falling sakura petals ── */
(function spawnPetals(){
  const colors=['#ffb7c5','#ff85a1','#fda4af','#f9a8d4','#fbcfe8'];
  for(let i=0;i<18;i++){
    const p=document.createElement('div');
    p.className='petal';
    const size=(Math.random()*8+6)+'px';
    p.style.cssText=`
      left:${Math.random()*100}%;
      width:${size};height:${size};
      background:${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration:${Math.random()*8+6}s;
      animation-delay:${Math.random()*8}s;
      border-radius:${Math.random()>.5?'50% 0 50% 0':'50%'};
      opacity:.7;
    `;
    document.body.appendChild(p);
  }
})();

/* ── Character reactions ── */
const pIn = document.getElementById('pass-in');
pIn.addEventListener('focus', ()=> document.body.classList.add('peeking'));
pIn.addEventListener('blur',  ()=> document.body.classList.remove('peeking'));

/* ── Validation ── */
const uIn  = document.getElementById('username-in');
const uMsg = document.getElementById('user-msg');
const pMsg = document.getElementById('pass-msg');

uIn.addEventListener('input', function(){
  const v=this.value.trim();
  if(!v){ uMsg.textContent=''; uMsg.className='field-msg'; this.className='field-input'; return; }
  if(v.length<3){ uMsg.textContent='At least 3 characters'; uMsg.className='field-msg err'; this.className='field-input error'; }
  else { uMsg.textContent='Looks good! ✓'; uMsg.className='field-msg ok'; this.className='field-input success'; }
});

pIn.addEventListener('input', function(){
  const v=this.value;
  const wrap=document.getElementById('s-bar-wrap'), bar=document.getElementById('s-bar');
  if(!v){ pMsg.textContent=''; pMsg.className='field-msg'; this.className='field-input'; wrap.classList.remove('show'); return; }
  wrap.classList.add('show');
  const s=strength(v);
  const labels=['Too short','Weak','Fair','Strong','Very strong'];
  const colors=['#ef4444','#f97316','#eab308','#22c55e','#10b981'];
  const widths=['20%','40%','60%','80%','100%'];
  pMsg.textContent='Strength: '+labels[s]; pMsg.style.color=colors[s]; pMsg.className='field-msg';
  bar.style.width=widths[s]; bar.style.background=colors[s];
  this.className=s<2?'field-input error':'field-input success';
});

function strength(p){ let s=0; if(p.length>=6)s++; if(p.length>=10)s++; if(/[A-Z]/.test(p))s++; if(/[0-9]/.test(p))s++; return Math.min(s,4); }

/* ── Eye toggle ── */
function togglePw(){
  const show=pIn.type==='text';
  pIn.type=show?'password':'text';
  document.getElementById('eye-icon').innerHTML=show
    ? '<path d="M1 8s3-5 7-5 7 5 7 5-3 5-7 5-7-5-7-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.5"/>'
    : '<path d="M2 2l12 12M6.5 6.6A2 2 0 0010 10M9.88 9.88A2 2 0 016.1 6.1M1 8s3-5 7-5c1.25 0 2.43.37 3.44 1M15 8s-1.3 1.84-3.5 3.09" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>';
}

/* ── Checkbox ── */
document.getElementById('remember').addEventListener('change', function(){
  document.getElementById('check-tick').style.opacity=this.checked?'1':'0';
});

/* ── Toast ── */
function showToast(msg,color){
  const t=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  document.getElementById('toast-dot').style.background=color||'#22c55e';
  t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),3000);
}

/* ── Login ── */
function handleLogin(e){
  e.preventDefault();
  const u=uIn.value.trim();
  const btn=document.getElementById('login-btn');

  if(!u||u.length<3){
    uIn.className='field-input error';
    uMsg.textContent='Username required'; uMsg.className='field-msg err';
    uIn.style.animation='none';
    requestAnimationFrame(()=>{ uIn.style.animation='shake .4s ease'; });
    return false;
  }

  btn.classList.add('rippling');
  setTimeout(()=>btn.classList.remove('rippling'),500);
  btn.classList.add('loading');

  setTimeout(()=>{
    btn.classList.remove('loading');
    document.body.classList.add('success-state');
    showToast('ようこそ '+u+'! Redirecting…','#a78bfa');
    uIn.className='field-input success';
    pIn.className=pIn.value?'field-input success':'field-input';
    setTimeout(()=>document.getElementById('login-form').submit(),1200);
  },1800);
  return false;
}
</script>
</body>
</html>
