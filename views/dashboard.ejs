<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Dashboard · <%= user %> · Cloud MIN</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@300;400;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}

:root{
  --teal:#39c5bb;
  --teal-dark:#2ba8a0;
  --teal-light:#e8faf9;
  --teal-mid:rgba(57,197,187,.12);
  --bg:#f0f4f8;
  --surface:#ffffff;
  --border:#e8edf2;
  --text:#2d3748;
  --text-mid:#718096;
  --text-light:#a0aec0;
  --green:#27ae60;
  --green-bg:rgba(39,174,96,.08);
  --green-border:rgba(39,174,96,.2);
  --amber:#f59e0b;
  --red:#e53e3e;
  --blue:#3b82f6;
  --shadow-sm:0 1px 4px rgba(0,0,0,.06);
  --shadow:0 4px 16px rgba(0,0,0,.08);
  --shadow-lg:0 12px 40px rgba(0,0,0,.12);
  --radius:16px;
  --radius-sm:10px;
}

html,body{
  min-height:100%;
  font-family:'Nunito',sans-serif;
  background:var(--bg);
  color:var(--text);
}

/* ── Background decoration ── */
body::before{
  content:'';position:fixed;top:-200px;right:-200px;
  width:600px;height:600px;border-radius:50%;
  background:radial-gradient(circle,rgba(57,197,187,.08) 0%,transparent 70%);
  pointer-events:none;z-index:0;
}
body::after{
  content:'';position:fixed;bottom:-150px;left:-150px;
  width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle,rgba(57,197,187,.06) 0%,transparent 70%);
  pointer-events:none;z-index:0;
}

.app{position:relative;z-index:1;min-height:100vh;display:flex;flex-direction:column}

/* ── Toast ── */
.toast{
  position:fixed;top:20px;left:50%;
  transform:translateX(-50%) translateY(-70px);
  background:var(--surface);border:1px solid var(--border);
  border-radius:50px;padding:10px 20px;
  color:var(--text);font-size:13px;font-weight:600;
  white-space:nowrap;display:flex;align-items:center;gap:8px;
  transition:transform .4s cubic-bezier(.22,1,.36,1),opacity .4s;
  opacity:0;z-index:200;
  box-shadow:var(--shadow-lg);
}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.toast-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}

/* ── Header ── */
header{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 32px;height:64px;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:50;
  box-shadow:var(--shadow-sm);
  animation:slideDown .5s cubic-bezier(.22,1,.36,1) both;
}
@keyframes slideDown{from{opacity:0;transform:translateY(-16px)}to{opacity:1;transform:translateY(0)}}

.brand{display:flex;align-items:center;gap:10px;text-decoration:none}
.brand-mark{
  width:36px;height:36px;border-radius:10px;
  background:linear-gradient(135deg,var(--teal),var(--teal-dark));
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 12px rgba(57,197,187,.35);
  flex-shrink:0;
}
.brand-mark svg{width:18px;height:18px;stroke:#fff;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round}
.brand-name{font-size:16px;font-weight:800;color:var(--text);letter-spacing:-.3px}
.brand-name span{color:var(--teal)}

.nav-center{display:flex;align-items:center;gap:4px}
.nav-link{
  padding:6px 14px;border-radius:8px;
  font-size:13px;font-weight:600;color:var(--text-mid);
  cursor:pointer;transition:background .15s,color .15s;
  border:none;background:transparent;font-family:'Nunito',sans-serif;
}
.nav-link:hover{background:var(--teal-light);color:var(--teal-dark)}
.nav-link.active{background:var(--teal-light);color:var(--teal)}

.nav-right{display:flex;align-items:center;gap:10px}
.pill{
  display:flex;align-items:center;gap:6px;
  background:var(--green-bg);border:1px solid var(--green-border);
  border-radius:50px;padding:5px 12px;
  font-size:12px;color:var(--green);font-weight:700;
}
.dot-pulse{
  width:7px;height:7px;background:var(--green);border-radius:50%;
  animation:dpulse 2s ease-in-out infinite;
}
@keyframes dpulse{0%,100%{box-shadow:0 0 0 0 rgba(39,174,96,.5)}50%{box-shadow:0 0 0 5px rgba(39,174,96,0)}}

.clock-badge{
  font-family:'JetBrains Mono',monospace;font-size:12px;
  color:var(--text-mid);background:var(--bg);
  border:1px solid var(--border);border-radius:8px;padding:5px 11px;
}
.avatar{
  width:36px;height:36px;border-radius:50%;
  background:linear-gradient(135deg,var(--teal),var(--teal-dark));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:14px;color:#fff;
  border:2px solid rgba(57,197,187,.25);
  cursor:default;transition:transform .2s,box-shadow .2s;
  flex-shrink:0;
}
.avatar:hover{transform:scale(1.08);box-shadow:0 4px 16px rgba(57,197,187,.4)}

/* logout btn */
.logout-btn{
  display:flex;align-items:center;gap:6px;
  padding:6px 14px;border-radius:8px;
  font-size:12.5px;font-weight:700;color:var(--text-mid);
  background:transparent;border:1px solid var(--border);
  cursor:pointer;font-family:'Nunito',sans-serif;
  transition:background .15s,color .15s,border-color .15s;
  text-decoration:none;
}
.logout-btn:hover{background:#fff5f5;color:var(--red);border-color:rgba(229,62,62,.2)}
.logout-btn svg{width:13px;height:13px}

/* ── Main ── */
main{flex:1;padding:28px 32px;max-width:1100px;margin:0 auto;width:100%}

/* ── Hero ── */
.hero{
  display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:24px;
  animation:fadeUp .5s .08s both;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.hero-left{}
.hero-tag{
  display:inline-flex;align-items:center;gap:6px;
  font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;
  color:var(--teal);background:var(--teal-light);
  border:1px solid rgba(57,197,187,.2);
  border-radius:50px;padding:3px 12px;margin-bottom:10px;
}
.hero-tag-dot{width:5px;height:5px;background:var(--teal);border-radius:50%}
.hero-title{font-size:28px;font-weight:800;color:var(--text);letter-spacing:-.5px;margin-bottom:4px}
.hero-title em{font-style:normal;color:var(--teal)}
.hero-sub{font-size:13.5px;color:var(--text-mid)}

.hero-actions{display:flex;align-items:center;gap:10px}
.btn-refresh{
  display:flex;align-items:center;gap:7px;
  padding:9px 18px;border-radius:50px;
  background:var(--teal);color:#fff;
  border:none;cursor:pointer;font-family:'Nunito',sans-serif;
  font-size:13px;font-weight:700;
  box-shadow:0 4px 16px rgba(57,197,187,.35);
  transition:transform .15s,box-shadow .2s;
}
.btn-refresh:hover{transform:translateY(-1px);box-shadow:0 8px 22px rgba(57,197,187,.45)}
.btn-refresh svg{width:14px;height:14px;stroke:#fff;fill:none;stroke-width:2.2;stroke-linecap:round}
.spin{animation:spin .6s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* ── Stat cards row ── */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
.sc{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);padding:18px 20px;
  position:relative;overflow:hidden;
  box-shadow:var(--shadow-sm);
  transition:transform .2s,box-shadow .2s;
  animation:fadeUp .5s both;
}
.sc:nth-child(1){animation-delay:.12s}
.sc:nth-child(2){animation-delay:.18s}
.sc:nth-child(3){animation-delay:.24s}
.sc:nth-child(4){animation-delay:.30s}
.sc:hover{transform:translateY(-3px);box-shadow:var(--shadow)}
.sc::after{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:0 0 2px 2px;
}
.sc.c-teal::after{background:linear-gradient(90deg,var(--teal),var(--teal-dark))}
.sc.c-green::after{background:linear-gradient(90deg,#27ae60,#2ecc71)}
.sc.c-amber::after{background:linear-gradient(90deg,#f59e0b,#fcd34d)}
.sc.c-blue::after{background:linear-gradient(90deg,#3b82f6,#60a5fa)}
.sc-icon{
  width:38px;height:38px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:18px;margin-bottom:12px;
}
.sc.c-teal .sc-icon{background:rgba(57,197,187,.12)}
.sc.c-green .sc-icon{background:rgba(39,174,96,.1)}
.sc.c-amber .sc-icon{background:rgba(245,158,11,.1)}
.sc.c-blue .sc-icon{background:rgba(59,130,246,.1)}
.sc-label{font-size:10.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--text-light);font-weight:700;margin-bottom:4px}
.sc-val{font-size:20px;font-weight:800;color:var(--text);display:flex;align-items:center;gap:8px}
.sc-badge{
  font-size:10px;padding:2px 8px;border-radius:50px;font-weight:700;
}
.sc-badge.teal{background:rgba(57,197,187,.12);color:var(--teal);border:1px solid rgba(57,197,187,.2)}
.sc-badge.green{background:var(--green-bg);color:var(--green);border:1px solid var(--green-border)}
.sc-badge.amber{background:rgba(245,158,11,.1);color:#d97706;border:1px solid rgba(245,158,11,.2)}
.sc-badge.blue{background:rgba(59,130,246,.1);color:#2563eb;border:1px solid rgba(59,130,246,.2)}

/* ── Grid ── */
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:14px}

/* ── Info card ── */
.ic{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius);padding:22px;
  box-shadow:var(--shadow-sm);
  transition:transform .2s,box-shadow .2s;
  animation:fadeUp .5s both;
}
.ic:nth-child(1){animation-delay:.36s}
.ic:nth-child(2){animation-delay:.42s}
.ic:nth-child(3){animation-delay:.48s}
.ic:nth-child(4){animation-delay:.54s}
.ic:hover{transform:translateY(-2px);box-shadow:var(--shadow)}

.ic-head{
  display:flex;align-items:center;gap:8px;
  margin-bottom:16px;
  font-size:13px;font-weight:800;color:var(--text);
}
.ic-accent{
  width:4px;height:18px;border-radius:4px;flex-shrink:0;
}
.ic-accent.teal{background:var(--teal)}
.ic-accent.green{background:var(--green)}
.ic-accent.amber{background:var(--amber)}
.ic-accent.blue{background:var(--blue)}
.ic-head-right{margin-left:auto}

.live-chip{
  display:inline-flex;align-items:center;gap:5px;
  font-size:10px;font-weight:700;letter-spacing:.05em;
  color:var(--green);background:var(--green-bg);
  border:1px solid var(--green-border);border-radius:50px;padding:3px 9px;
}
.live-dot{width:5px;height:5px;background:var(--green);border-radius:50%;animation:dpulse 1.5s infinite}

/* row */
.row{
  display:flex;align-items:center;justify-content:space-between;
  padding:9px 0;border-bottom:1px solid var(--border);
  font-size:13px;
}
.row:last-child{border-bottom:none}
.rl{color:var(--text-mid);font-weight:500}
.rv{font-weight:700;color:var(--text)}
.rv.teal{color:var(--teal)}
.rv.green{color:var(--green)}
.rv.amber{color:var(--amber)}
.rv.blue{color:var(--blue)}

/* progress bars */
.pb{margin-bottom:14px}
.pb:last-child{margin-bottom:0}
.pb-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.pb-label{font-size:12px;font-weight:700;color:var(--text-mid)}
.pb-pct{
  font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:500;
  color:var(--text-mid);
}
.pb-track{height:6px;background:#edf2f7;border-radius:10px;overflow:hidden}
.pb-fill{
  height:100%;border-radius:10px;width:0;
  transition:width .9s cubic-bezier(.22,1,.36,1);
}
.pb-fill.f-teal{background:linear-gradient(90deg,var(--teal),#6ee7e1)}
.pb-fill.f-green{background:linear-gradient(90deg,#27ae60,#6ee7b7)}
.pb-fill.f-red{background:linear-gradient(90deg,#e53e3e,#fc8181)}
.pb-fill.f-amber{background:linear-gradient(90deg,#f59e0b,#fcd34d)}
.warn-pct{color:#d97706 !important}
.crit-pct{color:#e53e3e !important}

/* activity feed */
.act{
  display:flex;align-items:center;gap:12px;
  padding:9px 0;border-bottom:1px solid var(--border);
}
.act:last-child{border-bottom:none}
.act-ico{
  width:30px;height:30px;border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:14px;
}
.act-ico.g{background:var(--green-bg)}
.act-ico.t{background:var(--teal-light)}
.act-ico.a{background:rgba(245,158,11,.1)}
.act-body{flex:1}
.act-text{font-size:13px;font-weight:600;color:var(--text)}
.act-sub{font-size:11px;color:var(--text-light);margin-top:1px}
.act-time{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text-light)}

/* region tag */
.region-tag{
  display:inline-flex;align-items:center;gap:5px;
  font-size:11px;font-weight:700;
  background:var(--teal-light);color:var(--teal-dark);
  border:1px solid rgba(57,197,187,.2);
  border-radius:50px;padding:3px 10px;
}

/* ── Footer ── */
footer{
  text-align:center;padding:16px;
  border-top:1px solid var(--border);
  background:var(--surface);
  font-size:12px;color:var(--text-light);
  animation:fadeUp .5s .7s both;
}
footer b{color:var(--teal);font-weight:700}

/* ── Responsive ── */
@media(max-width:900px){
  .stats{grid-template-columns:repeat(2,1fr)}
  .grid2,.grid3{grid-template-columns:1fr}
  .nav-center{display:none}
  header{padding:0 16px}
  main{padding:20px 16px}
}
@media(max-width:560px){
  .stats{grid-template-columns:1fr 1fr}
  .hero{flex-direction:column;gap:12px}
  .hero-title{font-size:22px}
}
</style>
</head>
<body>

<div class="toast" id="toast">
  <div class="toast-dot" id="toast-dot"></div>
  <span id="toast-msg"></span>
</div>

<div class="app">

  <!-- ── Header ── -->
  <header>
    <div class="brand">
      <div class="brand-mark">
        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      </div>
      <span class="brand-name">Cloud <span>MIN</span></span>
    </div>

    <div class="nav-center">
      <button class="nav-link active">Overview</button>
      <button class="nav-link">Servers</button>
      <button class="nav-link">Metrics</button>
      <button class="nav-link">Logs</button>
    </div>

    <div class="nav-right">
      <div class="pill"><div class="dot-pulse"></div>Operational</div>
      <div class="clock-badge" id="hclock">--:--:--</div>
      <div class="avatar"><%= user.charAt(0).toUpperCase() %></div>
      <a href="/logout" class="logout-btn">
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M6 2H3a1 1 0 00-1 1v10a1 1 0 001 1h3M10 11l3-3-3-3M13 8H6"/>
        </svg>
        Logout
      </a>
    </div>
  </header>

  <main>

    <!-- ── Hero ── -->
    <div class="hero">
      <div class="hero-left">
        <div class="hero-tag"><div class="hero-tag-dot"></div>Dashboard Overview</div>
        <h1 class="hero-title">Hello, <em><%= user %></em> 👋</h1>
        <p class="hero-sub">Live system stats — refreshing every 3 seconds</p>
      </div>
      <div class="hero-actions">
        <button class="btn-refresh" onclick="triggerRefresh()">
          <svg id="refresh-ico" viewBox="0 0 16 16"><path d="M13.5 2.5A7 7 0 102 8" stroke-linecap="round"/><path d="M2 3.5V8H6.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Refresh
        </button>
      </div>
    </div>

    <!-- ── 4 stat cards ── -->
    <div class="stats">
      <div class="sc c-teal">
        <div class="sc-icon">🖥️</div>
        <div class="sc-label">Active Server</div>
        <div class="sc-val" style="font-size:15px"><span id="s-hostname"><%= server %></span></div>
      </div>
      <div class="sc c-green">
        <div class="sc-icon">✅</div>
        <div class="sc-label">App Status</div>
        <div class="sc-val">Running <span class="sc-badge green">Healthy</span></div>
      </div>
      <div class="sc c-amber">
        <div class="sc-icon">📊</div>
        <div class="sc-label">Load Average</div>
        <div class="sc-val"><span id="s-load">–</span> <span class="sc-badge amber">1m avg</span></div>
      </div>
      <div class="sc c-blue">
        <div class="sc-icon">⏱️</div>
        <div class="sc-label">App Uptime</div>
        <div class="sc-val" style="font-size:14px;font-family:'JetBrains Mono',monospace"><span id="s-appuptime">–</span></div>
      </div>
    </div>

    <!-- ── Row 1: Server Info + Resource Usage ── -->
    <div class="grid2">

      <div class="ic">
        <div class="ic-head">
          <div class="ic-accent teal"></div>
          Server Information
          <div class="ic-head-right"><span class="live-chip"><span class="live-dot"></span>LIVE</span></div>
        </div>
        <div class="row"><span class="rl">Hostname</span><span class="rv teal" id="d-hostname">–</span></div>
        <div class="row"><span class="rl">Platform / Arch</span><span class="rv" id="d-platform">–</span></div>
        <div class="row"><span class="rl">CPU Cores</span><span class="rv" id="d-cores">–</span></div>
        <div class="row"><span class="rl">Total Memory</span><span class="rv" id="d-totalmem">–</span></div>
        <div class="row"><span class="rl">Free Memory</span><span class="rv green" id="d-freemem">–</span></div>
        <div class="row"><span class="rl">OS Uptime</span><span class="rv amber" id="d-osuptime">–</span></div>
      </div>

      <div class="ic">
        <div class="ic-head">
          <div class="ic-accent green"></div>
          Resource Usage
          <div class="ic-head-right"><span class="live-chip"><span class="live-dot"></span>LIVE</span></div>
        </div>
        <div class="pb">
          <div class="pb-row">
            <span class="pb-label">CPU Usage</span>
            <span class="pb-pct" id="cpu-pct">–%</span>
          </div>
          <div class="pb-track"><div class="pb-fill f-teal" id="cpu-bar"></div></div>
        </div>
        <div class="pb">
          <div class="pb-row">
            <span class="pb-label">Memory</span>
            <span class="pb-pct" id="mem-pct">–%</span>
          </div>
          <div class="pb-track"><div class="pb-fill f-green" id="mem-bar"></div></div>
        </div>
        <div class="pb">
          <div class="pb-row">
            <span class="pb-label">Disk</span>
            <span class="pb-pct" id="disk-pct">–%</span>
          </div>
          <div class="pb-track"><div class="pb-fill f-red" id="disk-bar"></div></div>
        </div>
        <div class="pb">
          <div class="pb-row">
            <span class="pb-label">Network I/O</span>
            <span class="pb-pct" id="net-pct">–%</span>
          </div>
          <div class="pb-track"><div class="pb-fill f-amber" id="net-bar"></div></div>
        </div>
      </div>

    </div>

    <!-- ── Row 2: Deployment + CPU Detail + Activity ── -->
    <div class="grid3">

      <div class="ic">
        <div class="ic-head"><div class="ic-accent teal"></div>Deployment</div>
        <div class="row"><span class="rl">Environment</span><span class="rv" id="d-env">–</span></div>
        <div class="row">
          <span class="rl">Region</span>
          <span class="region-tag" id="d-region">–</span>
        </div>
        <div class="row"><span class="rl">Server Name</span><span class="rv teal"><%= server %></span></div>
        <div class="row"><span class="rl">Build</span><span class="rv blue" id="d-version">–</span></div>
      </div>

      <div class="ic">
        <div class="ic-head"><div class="ic-accent amber"></div>CPU Detail</div>
        <div class="row"><span class="rl">Model</span><span class="rv" id="d-cpumodel" style="font-size:11.5px;text-align:right;max-width:56%">–</span></div>
        <div class="row"><span class="rl">Cores</span><span class="rv" id="d-cores2">–</span></div>
        <div class="row"><span class="rl">Load 1m</span><span class="rv amber" id="d-load1">–</span></div>
        <div class="row"><span class="rl">Load 5m</span><span class="rv" id="d-load5">–</span></div>
        <div class="row"><span class="rl">Load 15m</span><span class="rv" id="d-load15">–</span></div>
      </div>

      <div class="ic">
        <div class="ic-head"><div class="ic-accent green"></div>Recent Activity</div>
        <div class="act">
          <div class="act-ico g">✅</div>
          <div class="act-body">
            <div class="act-text">Health check passed</div>
            <div class="act-sub">All endpoints responding</div>
          </div>
          <span class="act-time">just now</span>
        </div>
        <div class="act">
          <div class="act-ico t">👤</div>
          <div class="act-body">
            <div class="act-text"><%= user %> signed in</div>
            <div class="act-sub">Session started</div>
          </div>
          <span class="act-time" id="loginTime">–</span>
        </div>
        <div class="act">
          <div class="act-ico g">🔄</div>
          <div class="act-body">
            <div class="act-text">Stats API polled</div>
            <div class="act-sub">Live data active</div>
          </div>
          <span class="act-time" id="lastPoll">–</span>
        </div>
        <div class="act">
          <div class="act-ico a">⚡</div>
          <div class="act-body">
            <div class="act-text">Load balancer synced</div>
            <div class="act-sub">All regions healthy</div>
          </div>
          <span class="act-time">3m ago</span>
        </div>
      </div>

    </div>

  </main>

  <footer>
    Handled by <b><%= server %></b> &nbsp;·&nbsp;
    Region: <b id="f-region">–</b> &nbsp;·&nbsp;
    Cloud MIN &nbsp;<b id="f-version">–</b>
  </footer>

</div><!-- /app -->

<script>
/* ─── Clock ─── */
function tick(){
  document.getElementById('hclock').textContent = new Date().toLocaleTimeString();
}
tick(); setInterval(tick, 1000);

/* ─── Login time ─── */
document.getElementById('loginTime').textContent =
  new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});

/* ─── Toast ─── */
function showToast(msg, color){
  const t = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  document.getElementById('toast-dot').style.background = color || '#39c5bb';
  t.classList.add('show');
  setTimeout(()=> t.classList.remove('show'), 3200);
}

/* ─── Refresh button ─── */
function triggerRefresh(){
  const ico = document.getElementById('refresh-ico');
  ico.classList.add('spin');
  fetchStats().finally(()=> setTimeout(()=> ico.classList.remove('spin'), 600));
}

/* ─── Bar helper ─── */
function setBar(barId, pctId, value, barClass){
  if(value === null || value === undefined) return;
  const bar = document.getElementById(barId);
  const pct = document.getElementById(pctId);
  bar.style.width = value + '%';
  pct.textContent = value + '%';
  pct.className = 'pb-pct' + (value >= 90 ? ' crit-pct' : value >= 75 ? ' warn-pct' : '');
}

/* ─── Fetch stats ─── */
async function fetchStats(){
  try {
    const res  = await fetch('/api/stats');
    const data = await res.json();

    setBar('cpu-bar',  'cpu-pct',  data.cpu);
    setBar('mem-bar',  'mem-pct',  data.mem);
    setBar('disk-bar', 'disk-pct', data.disk);
    setBar('net-bar',  'net-pct',  data.net !== null ? data.net : 0);

    const set = (id, val) => { const el = document.getElementById(id); if(el && val !== undefined) el.textContent = val; };

    set('d-hostname',  data.hostname);
    set('d-platform',  data.platform + ' / ' + data.arch);
    set('d-cores',     data.cpuCores + ' cores');
    set('d-totalmem',  data.totalMem + ' GB');
    set('d-freemem',   data.freeMem + ' GB free');
    set('d-osuptime',  data.osUptime);
    set('s-hostname',  data.hostname);
    set('s-load',      data.loadAvg[0]);
    set('s-appuptime', data.appUptime);
    set('d-cpumodel',  data.cpuModel);
    set('d-cores2',    data.cpuCores + ' cores');
    set('d-load1',     data.loadAvg[0]);
    set('d-load5',     data.loadAvg[1]);
    set('d-load15',    data.loadAvg[2]);
    set('d-env',       data.env     || 'production');
    set('d-region',    data.region  || '–');
    set('d-version',   data.version || '–');
    set('f-region',    data.region  || '–');
    set('f-version',   data.version || '–');
    set('d-appuptime', data.appUptime);

    document.getElementById('lastPoll').textContent =
      new Date().toLocaleTimeString([],{hour:'2-digit',minute:'2-digit',second:'2-digit'});

  } catch(e){
    console.warn('Stats fetch failed:', e);
  }
}

fetchStats();
setInterval(fetchStats, 3000);

setTimeout(() => showToast('Welcome back, <%= user %>! Dashboard is live.', '#39c5bb'), 700);
</script>
</body>
</html>
